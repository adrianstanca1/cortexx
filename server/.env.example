# Cortexx API — environment
# Copy to .env and fill in. Never commit the real .env.

# PostgreSQL connection string
DATABASE_URL=postgres://localhost/cortexx

# CORS — comma-separated list of ALLOWED browser origins that may call the API.
# REQUIRED in production: the server refuses to boot (exit 1) if this is unset when
# NODE_ENV=production. In development it defaults to a localhost allowlist.
# Examples:
#   CORS_ORIGINS=https://cortexbuildpro.com,https://app.cortexx.cortexx
#   CORS_ORIGINS=http://localhost:8080,http://127.0.0.1:8080
CORS_ORIGINS=

# Sign JWTs with this — generate: openssl rand -hex 32
JWT_SECRET=change-me-openssl-rand-hex-32

# Server-side Claude key — OPTIONAL. Only needed if you keep the legacy
# /api/ai cloud proxy enabled. The new /api/llm route uses a LOCAL LLM
# (Ollama by default — see below) and needs no API key.
ANTHROPIC_API_KEY=

# Public URL of the frontend (used in magic-link emails)
APP_URL=https://cortexbuildpro.com

# Port the API listens on
PORT=3001

# Set to 'production' to send real magic-link emails instead of returning them
NODE_ENV=development

# ── Magic-link email delivery ───────────────────────────────
# If RESEND_API_KEY is set, sign-in links are emailed via Resend
# (https://resend.com). If unset, the link is logged to the server console
# (dev) — never silently dropped. Swap for SES/Postmark by editing
# the /api/auth/magic/request handler.
RESEND_API_KEY=
MAIL_FROM=CortexBuild Pro <login@cortexbuildpro.com>

# ── AI agents (v1.4) ────────────────────────────────────────
# Shared secret in webhook URLs: /api/webhooks/<secret>/whatsapp
WEBHOOK_SECRET=set-a-long-random-string
# Meta WhatsApp Business API verify token (handshake)
WA_VERIFY_TOKEN=your-meta-verify-token
# Workspace that inbound webhook leads are filed into
DEFAULT_WORKSPACE_ID=00000000-0000-0000-0000-000000000001

# ── Push notifications (v1.3) ───────────────────────────────
# Generate VAPID keys once: npx web-push generate-vapid-keys
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:sales@cortexbuildpro.com

# ── Open Banking (TrueLayer) — v1.3 ─────────────────────────
# Sign up at https://console.truelayer.com — start in sandbox.
TRUELAYER_CLIENT_ID=
TRUELAYER_CLIENT_SECRET=
TRUELAYER_REDIRECT_URI=https://cortexbuildpro.com/api/banking/callback
TRUELAYER_ENV=sandbox
# AES-256-GCM key for token-at-rest. Generate: openssl rand -hex 32
BANKING_ENC_KEY=
# Where banking/callback redirects after consent
PUBLIC_BASE_URL=https://cortexbuildpro.com

# ── In-app subscriptions (v1.3) ─────────────────────────────
# Apple StoreKit (server-side receipt validation)
# Get from App Store Connect → Users and Access → Integrations → In-App Purchase
APPLE_SHARED_SECRET=
# Stripe — web subscription checkout (reuses STRIPE_SECRET_KEY above)
# Webhook secret for /api/iap/webhook
STRIPE_WEBHOOK_SECRET=

# ── HMRC Government Gateway (v1.3) ──────────────────────────
# CIS300 monthly return submission via GovTalk / Transaction Engine.
# HMRC_ENV=tpvs uses the test Transaction Engine (GatewayTest=true);
# HMRC_ENV=live submits for real. Pass TPVS testing before going live.
HMRC_GATEWAY_USER=
HMRC_GATEWAY_PASS=
HMRC_ENV=tpvs
# Your registered vendor ID from HMRC Online Services
HMRC_VENDOR_ID=0000

# ── Crash reporting (v1.1) ──────────────────────────────────
# Optional. Frontend uses CortexCrash.init({dsn}) from localStorage too.
# Pass through to clients via the marketing snippet if you want auto-init.
SENTRY_DSN=

# ── Payment links (v1.3) ────────────────────────────────────
# Stripe — create payment links for invoices. Get key at dashboard.stripe.com
# Use sk_test_… in development; sk_live_… in production
STRIPE_SECRET_KEY=
# GoCardless — for UK Direct Debit collections (api.gocardless.com)
# Use the sandbox base in dev: https://api-sandbox.gocardless.com
GOCARDLESS_ACCESS_TOKEN=
GOCARDLESS_BASE=https://api.gocardless.com
# UK bank-transfer details (no third party — rendered to client)
BANK_ACCOUNT_NAME=CortexBuild Ltd
BANK_SORT_CODE=
BANK_ACCOUNT_NO=
BANK_IBAN=
# Default: Ollama on the same host. Install with one line:
#   curl -fsSL https://ollama.com/install.sh | sh
# Then pull the models:
#   ollama pull llama3.2:3b   # text
#   ollama pull llava         # vision (optional, only used for image inputs)
LLM_RUNTIME=ollama
OLLAMA_BASE=http://localhost:11434
OLLAMA_MODEL=llama3.2:3b
OLLAMA_VISION_MODEL=llava
LLM_TIMEOUT_MS=60000
# Or point at any OpenAI-compatible runtime (llama.cpp server, vLLM, LM Studio):
# LLM_RUNTIME=openai_compat
# OPENAI_COMPAT_BASE=http://localhost:8080
# OPENAI_COMPAT_MODEL=default
