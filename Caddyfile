# CortexBuild Pro — Caddy reverse proxy + static host
# Free automatic HTTPS (Let's Encrypt) when SITE_ADDRESS is a real domain.
# Falls back to plain HTTP on :80 for IP-only deploys.
#
# SITE_ADDRESS is injected from the environment by docker-compose.
{$SITE_ADDRESS} {
	# ── Static app (Cortexx.html + lib/ + dist/ + portal.html + assets) ──
	root * /srv/app
	encode gzip zstd

	# ── API + realtime + webhooks → Node service ──
	handle /api/* {
		reverse_proxy api:3001
	}

	# ── Everything else → the SPA shell ──
	handle {
		try_files {path} /Cortexx.html
		file_server
	}

	# App code in /lib and /dist is NOT content-hashed, so it must never be
	# pinned as immutable — otherwise a returning browser keeps running old code
	# (including security fixes) for up to a year. Revalidate it every load; the
	# service worker's network-first strategy depends on this.
	@appcode path /lib/* /dist/*
	header @appcode Cache-Control "no-cache, must-revalidate"

	# Long-cache genuinely static assets (icons, fonts) — but exclude app code.
	@static {
		path *.js *.css *.png *.jpg *.svg *.woff2
		not path /lib/* /dist/*
	}
	header @static Cache-Control "public, max-age=31536000, immutable"
	@html path *.html
	header @html Cache-Control "no-cache"
}
