# Production-style env for Cortexx — copy to .env.local for dev

# PostgreSQL connection string
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/cortexx"

# NextAuth — required
# Generate a 32+ char random string for production:
#   openssl rand -base64 32
NEXTAUTH_SECRET="dev-secret-change-me-please-32-chars-min"
NEXTAUTH_URL="http://localhost:3000"

# Optional — for `prisma db seed`:
ADMIN_EMAIL="admin@cortexbuildpro.com"
ADMIN_PASSWORD="changeme-please-1234"

# Optional — for the /api/seed HTTP endpoint (only honoured if ALLOW_SEED=true)
ALLOW_SEED="false"
SEED_TOKEN="dev-only-do-not-use-in-prod"

# Where /api/uploads writes file bytes. Defaults to ./uploads.
# In production, point this at a persistent volume e.g. /var/lib/cortexx/uploads.
UPLOAD_DIR="./uploads"

# Public canonical URL — used for openGraph / twitter card metadata.
NEXT_PUBLIC_SITE_URL="https://cortexbuildpro.com"

# Local LLM (Ollama) for /ask. Defaults assume Ollama on localhost.
# Install: curl -fsSL https://ollama.com/install.sh | sh
# Pull a model: ollama pull llama3.2:3b
OLLAMA_BASE_URL="http://localhost:11434"
OLLAMA_MODEL="llama3.2:3b"
