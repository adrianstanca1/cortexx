# =============================================================================
# Cortexx — environment reference
# =============================================================================
# Copy to .env.local for local development. Production reads the same names
# from the shell or systemd unit env. Variables marked REQUIRED must be set
# for the app to boot; OPTIONAL ones unlock features when present and the
# code degrades gracefully otherwise.
# =============================================================================


# ── Core ─────────────────────────────────────────────────────────────────────

# REQUIRED — PostgreSQL connection string. Prisma reads this directly.
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/cortexx"

# REQUIRED — Auth.js v5 session secret. Generate with:
#   openssl rand -base64 32
NEXTAUTH_SECRET="dev-secret-change-me-please-32-chars-min"

# REQUIRED — Canonical app URL. Used by Auth.js for OAuth redirects, by
# /robots.ts and /sitemap.ts for the absolute URL, and by cron emails for
# the deep-links into the dashboard.
NEXTAUTH_URL="http://localhost:3000"

# REQUIRED — Public canonical URL. Used for openGraph / twitter card metadata
# on the root layout, and for social previews.
NEXT_PUBLIC_SITE_URL="https://cortexbuildpro.com"


# ── Multi-tenancy ────────────────────────────────────────────────────────────

# OPTIONAL — set to 'true' to activate the Prisma tenancy extension that
# auto-injects organizationId filters on every owned-model query. Production
# has this set to true (deploy-vps.yml writes it into .env.production).
# Local dev typically leaves it unset / 'false' so the seed user works without
# an explicit org context. See lib/tenancy.ts.
MULTITENANT_ENFORCED="false"


# ── Cache & cluster ──────────────────────────────────────────────────────────

# OPTIONAL — Redis URL. When set, lib/rateLimit.ts shares the sliding-window
# counters across pm2 cluster workers so 60-req/min/user means 60, not
# 60×workers. Without it, each worker has its own counter (fine for dev).
REDIS_URL="redis://localhost:6379"


# ── Web push notifications ───────────────────────────────────────────────────

# OPTIONAL — VAPID keypair for web-push. Without these, /api/push/subscribe
# still records subscriptions but lib/push.ts logs a warning instead of
# dispatching. Generate with:
#   npx web-push generate-vapid-keys --json
VAPID_PUBLIC_KEY=""
VAPID_PRIVATE_KEY=""
# REQUIRED if VAPID is set — contact email Apple/Google use to reach you
# about high-volume push abuse.
VAPID_CONTACT_EMAIL="mailto:ops@cortexbuildpro.com"
# Public copy of VAPID_PUBLIC_KEY — read by the service worker registration
# code in the browser. Must match VAPID_PUBLIC_KEY exactly.
NEXT_PUBLIC_VAPID_PUBLIC_KEY=""


# ── Stripe billing ───────────────────────────────────────────────────────────

# OPTIONAL — without these, /api/billing/checkout returns 503 and the
# /pricing page hides the "Subscribe" CTAs.
STRIPE_SECRET_KEY="sk_test_..."
STRIPE_WEBHOOK_SECRET="whsec_..."
# Stripe price IDs for the three plans. Validated at boot — boot fails if
# Stripe is enabled but any price ID is missing.
STRIPE_PRICE_STARTER="price_..."
STRIPE_PRICE_PRO="price_..."
STRIPE_PRICE_ENTERPRISE="price_..."


# ── Sentry error reporting ───────────────────────────────────────────────────

# OPTIONAL — without SENTRY_DSN, lib/sentry.ts and instrumentation.ts are
# no-ops. /api/errors still logs to stdout.
SENTRY_DSN=""
SENTRY_ENVIRONMENT="production"
# Set to the git SHA of the deploy so Sentry tags events with the release.
# deploy-vps.yml exports GITHUB_SHA which the workflow uses as SENTRY_RELEASE.
SENTRY_RELEASE=""


# ── Transactional email (Resend) ─────────────────────────────────────────────

# OPTIONAL — without RESEND_API_KEY, lib/email.ts logs the would-be email
# to stdout. Invite emails, cron digests, and 2FA codes all flow through
# this helper.
RESEND_API_KEY=""
EMAIL_FROM="Cortexx <hello@cortexbuildpro.com>"
EMAIL_REPLY_TO="support@cortexbuildpro.com"


# ── File uploads ─────────────────────────────────────────────────────────────

# Where /api/uploads writes file bytes. Defaults to ./uploads.
# In production point this at a persistent volume e.g. /var/lib/cortexx/uploads.
UPLOAD_DIR="./uploads"


# ── S3-compatible object storage (optional alternative to UPLOAD_DIR) ────────

# OPTIONAL — when S3_BUCKET is set, lib/storage.ts switches from disk to
# S3. Works with AWS S3, Cloudflare R2, MinIO, Backblaze B2.
S3_BUCKET=""
S3_REGION="auto"
S3_ENDPOINT=""              # e.g. https://<account>.r2.cloudflarestorage.com
S3_ACCESS_KEY_ID=""
S3_SECRET_ACCESS_KEY=""
# 'true' if the bucket has a public read policy and getPublicUrl() should
# return https://<bucket>/<key> directly; 'false' to use presigned URLs.
S3_PUBLIC_READ="false"
# Presigned URL TTL when S3_PUBLIC_READ=false. Default 3600 = 1 hour.
S3_URL_EXPIRY_SECS="3600"


# ── Local LLM (Ollama) ───────────────────────────────────────────────────────

# OPTIONAL — without Ollama running, /ask returns an explanatory error and
# the vision pipelines (snag/photo/drawing analyze) return *_UNAVAILABLE.
# Install: curl -fsSL https://ollama.com/install.sh | sh
# Pull models: ollama pull llama3.2:3b && ollama pull moondream
OLLAMA_BASE_URL="http://localhost:11434"
OLLAMA_MODEL="llama3.2:3b"
OLLAMA_VISION_MODEL="moondream"


# ── Voice transcription (whisper.cpp + ffmpeg) ───────────────────────────────

# OPTIONAL — without whisper.cpp built, /api/transcribe returns
# WHISPER_UNAVAILABLE and the voice-RFI flow falls back to audio-only.
# deploy-vps.yml installs and builds whisper.cpp idempotently at /opt/whisper.cpp.
WHISPER_BIN="/opt/whisper.cpp/main"
WHISPER_MODEL="/opt/whisper.cpp/models/ggml-base.en.bin"
FFMPEG_BIN="ffmpeg"


# ── Cron bearer auth ─────────────────────────────────────────────────────────

# REQUIRED in production — bearer token that /api/cron/* routes verify.
# Set as a GitHub Actions secret if you trigger crons via workflow_dispatch
# from .github/workflows/cron-*.yml, or as a header on whatever scheduler
# (Hostinger cron, Fly Machines, etc.) calls these endpoints.
CRON_SECRET=""


# ── Seeding & admin bootstrap ────────────────────────────────────────────────

# Used by `prisma db seed` (npm run db:seed). Creates the initial admin
# user inside the default workspace.
ADMIN_EMAIL="admin@cortexbuildpro.com"
ADMIN_PASSWORD="changeme-please-1234"

# /api/seed HTTP endpoint — only honoured when ALLOW_SEED=true AND the
# request carries the SEED_TOKEN as a bearer header. Used for one-shot
# re-seeds; keep ALLOW_SEED=false in production once the workspace is set up.
ALLOW_SEED="false"
SEED_TOKEN="dev-only-do-not-use-in-prod"


# ── Telemetry & analytics ────────────────────────────────────────────────────

# OPTIONAL — fraction of page loads that emit Web Vitals to /api/metrics.
# Default 0.1 (10%). Set to "1" for full sampling in low-traffic envs.
NEXT_PUBLIC_VITALS_SAMPLE_RATE="0.1"

# OPTIONAL — set to 'true' to open the @next/bundle-analyzer treemap on
# `npm run build`. Don't enable in CI.
ANALYZE=""
