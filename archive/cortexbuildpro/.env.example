# CortexBuild Pro — Environment Variables
# Copy to .env.local and fill in your values
# DO NOT commit .env files to git

# Expo / App Configuration
EXPO_PUBLIC_APP_NAME=CortexBuild Pro
EXPO_PUBLIC_APP_VERSION=1.0.0

# Supabase (Backend)
EXPO_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# API
EXPO_PUBLIC_API_URL=https://api.cortexbuild.com

# EAS Build
EXPO_PUBLIC_EAS_PROJECT_ID=your-eas-project-id
EXPO_PUBLIC_IOS_BUNDLE_IDENTIFIER=com.cortexbuild.pro
EXPO_PUBLIC_ANDROID_PACKAGE=com.cortexbuild.pro

# Feature Flags
EXPO_PUBLIC_ENABLE_ANALYTICS=false
EXPO_PUBLIC_ENABLE_CRASHLYTICS=false

# Development
# NODE_ENV=development
