# PM2 + Nginx on the host (not Docker). Copy via scripts/vps-install-nginx-site.sh
# or: sed and install to /etc/nginx/sites-available/ then enable the site.
#
# Replace @@PRIMARY_DOMAIN@@ with your public hostname (e.g. field.example.com).
# Replace @@WEB_ROOT@@ with the directory that holds the Expo web export (index.html).
# API must listen on @@API_PORT@@ (default 3005 — see ecosystem.config.cjs).

upstream cortexbuild_api {
    server 127.0.0.1:@@API_PORT@@;
    keepalive 32;
}

server {
    listen 80;
    listen [::]:80;
    server_name @@PRIMARY_DOMAIN@@;

    # Security headers (HSTS becomes meaningful once certbot adds TLS).
    add_header Strict-Transport-Security "max-age=31536000; includeSubDomains" always;
    add_header X-Content-Type-Options "nosniff" always;
    add_header X-Frame-Options "DENY" always;
    add_header Referrer-Policy "strict-origin-when-cross-origin" always;
    add_header Permissions-Policy "geolocation=(self), microphone=(self), camera=()" always;
    # CSP intentionally omitted — Expo's web bundle currently uses inline
    # scripts; enable once the build supports nonces or hashes cleanly.

    client_max_body_size 50m;

    location /api/ {
        proxy_pass         http://cortexbuild_api;
        proxy_http_version 1.1;
        proxy_set_header   Upgrade $http_upgrade;
        proxy_set_header   Connection "upgrade";
        proxy_set_header   Host $host;
        proxy_set_header   X-Real-IP $remote_addr;
        proxy_set_header   X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header   X-Forwarded-Proto $scheme;
        proxy_read_timeout   120s;
        proxy_send_timeout   120s;
    }

    location /oauth/ {
        proxy_pass         http://cortexbuild_api;
        proxy_http_version 1.1;
        proxy_set_header   Host $host;
        proxy_set_header   X-Real-IP $remote_addr;
        proxy_set_header   X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header   X-Forwarded-Proto $scheme;
    }

    location /manus-storage/ {
        proxy_pass         http://cortexbuild_api;
        proxy_http_version 1.1;
        proxy_set_header   Host $host;
        proxy_set_header   X-Real-IP $remote_addr;
        proxy_set_header   X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header   X-Forwarded-Proto $scheme;
    }

    location / {
        root @@WEB_ROOT@@;
        index index.html;
        try_files $uri $uri/ /index.html;
    }
}
