{
  "cli": {
    "version": ">= 12.0.0",
    "appVersionSource": "remote"
  },
  "build": {
    "development": {
      "developmentClient": true,
      "distribution": "internal",
      "ios": {
        "simulator": false,
        "resourceClass": "m-medium"
      },
      "android": {
        "buildType": "apk",
        "resourceClass": "medium"
      },
      "env": {
        "APP_ENV": "development"
      }
    },
    "preview": {
      "distribution": "internal",
      "ios": {
        "simulator": false,
        "resourceClass": "m-medium"
      },
      "android": {
        "buildType": "apk",
        "resourceClass": "medium"
      },
      "env": {
        "APP_ENV": "preview",
        "API_URL": "https://field.cortexbuildpro.com"
      }
    },
    "simulator": {
      "ios": {
        "simulator": true,
        "resourceClass": "m-medium"
      },
      "env": {
        "APP_ENV": "preview",
        "API_URL": "https://field.cortexbuildpro.com"
      }
    },
    "production": {
      "autoIncrement": true,
      "ios": {
        "resourceClass": "m-medium"
      },
      "android": {
        "buildType": "app-bundle",
        "resourceClass": "medium"
      },
      "env": {
        "APP_ENV": "production",
        "API_URL": "https://field.cortexbuildpro.com"
      }
    }
  },
  "submit": {
    "production": {
      "ios": {
        "appleId": "Adrian.stanca1@gmail.com",
        "appleTeamId": "4G3G5MX9BH",
        "ascApiKeyPath": "./AuthKey_S7PSXPJ963.p8",
        "ascApiKeyId": "S7PSXPJ963",
        "ascApiKeyIssuerId": "4e694aa4-8cbc-4de4-bdf2-0ace72694564"
      },
      "android": {
        "serviceAccountKeyPath": "./google-service-account.json",
        "track": "internal"
      }
    }
  }
}
