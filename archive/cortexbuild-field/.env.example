# Environment Variables Template
# Copy this file to .env and fill in your values
# DO NOT commit .env to git

# Server
NODE_ENV=development
PORT=3005

# JWT (generate with: openssl rand -hex 64)
JWT_SECRET=your-64-char-hex-secret-here
SESSION_SECRET=your-64-char-hex-secret-here

# Database
DATABASE_URL=postgresql://user:password@localhost:5432/dbname
REDIS_URL=redis://127.0.0.1:6379

# Email
SENDGRID_API_KEY=your-sendgrid-api-key
EMAIL_FROM=noreply@cortexbuildpro.com
EMAIL_FROM_NAME=CortexBuild Field
BREVO_API_KEY=your-brevo-api-key

# OAuth / Manus Integration
OWNER_OPEN_ID=email:your-email@example.com
EXPO_PUBLIC_OWNER_OPEN_ID=email:your-email@example.com
OAUTH_SERVER_URL=https://your-oauth-server.com

# Registration
REGISTRATION_ALLOWED_DOMAINS=yourdomain.com

# Feature Flags
REQUIRE_DATABASE=true
PUSH_GATE_FAIL_MODE=warn

# ── MinIO S3 Storage (server-only) ────────────────────────────────────────────
# Leave S3_ENDPOINT empty to fall back to local filesystem (development).
# In production, set all six variables after provisioning MinIO (see DEPLOY.md).
S3_ENDPOINT=http://127.0.0.1:9000
S3_BUCKET=cortexbuild-field
S3_ACCESS_KEY_ID=your-minio-access-key
S3_SECRET_ACCESS_KEY=your-minio-secret-key
S3_REGION=us-east-1
S3_FORCE_PATH_STYLE=true
