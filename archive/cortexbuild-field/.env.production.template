# CortexBuild Field — Production Environment Template
# Copy this file to .env and fill in all values before deploying
# NEVER commit .env to version control

# ── Database ──────────────────────────────────────────────────────────────────
DATABASE_URL=mysql://USER:PASSWORD@HOST:4000/cortexbuild?ssl={"rejectUnauthorized":true}

# ── Server ────────────────────────────────────────────────────────────────────
NODE_ENV=production
PORT=3000

# ── Auth / Session ────────────────────────────────────────────────────────────
# Generate with: openssl rand -hex 32
JWT_SECRET=REPLACE_WITH_64_CHAR_HEX_STRING
SESSION_SECRET=REPLACE_WITH_ANOTHER_64_CHAR_HEX_STRING

# ── OAuth ─────────────────────────────────────────────────────────────────────
OAUTH_GOOGLE_CLIENT_ID=
OAUTH_GOOGLE_CLIENT_SECRET=
OAUTH_CALLBACK_URL=https://YOUR_DOMAIN/oauth/callback

# ── Push Notifications ────────────────────────────────────────────────────────
EXPO_ACCESS_TOKEN=

# ── Storage (S3-compatible) ───────────────────────────────────────────────────
STORAGE_ENDPOINT=https://s3.eu-west-2.amazonaws.com
STORAGE_BUCKET=cortexbuild-field
STORAGE_ACCESS_KEY=
STORAGE_SECRET_KEY=
STORAGE_REGION=eu-west-2

# ── Email / SMTP ──────────────────────────────────────────────────────────────
SMTP_HOST=smtp.sendgrid.net
SMTP_PORT=587
SMTP_USER=apikey
SMTP_PASS=YOUR_SENDGRID_API_KEY
SMTP_FROM=noreply@cortexbuild.co.uk

# ── App URL ───────────────────────────────────────────────────────────────────
APP_URL=https://YOUR_DOMAIN

# ── Self-service registration ────────────────────────────────────────────────
# Comma-separated email-domain whitelist for auth.register. Empty = disabled.
# Example: cortexbuildpro.com,partner.example
REGISTRATION_ALLOWED_DOMAINS=

# ── Owner auto-promotion ─────────────────────────────────────────────────────
# Email-prefixed openId of the user auto-promoted to admin on upsert.
# Example: email:owner@example.com
OWNER_OPEN_ID=
