{
  "name": "app-template",
  "version": "1.0.0",
  "private": true,
  "main": "expo-router/entry",
  "scripts": {
    "dev": "concurrently -k \"pnpm dev:server\" \"pnpm dev:metro\"",
    "dev:server": "cross-env NODE_ENV=development tsx watch server/_core/index.ts",
    "dev:metro": "cross-env EXPO_USE_METRO_WORKSPACE_ROOT=1 npx expo start --web --port ${EXPO_PORT:-8081}",
    "build": "esbuild server/_core/index.ts --platform=node --packages=external --bundle --format=esm --outdir=dist && node -e \"require('fs').writeFileSync('dist/package.json', JSON.stringify({type:'module'}))\"",
    "start": "NODE_ENV=production node dist/index.js",
    "check": "tsc --noEmit",
    "lint": "expo lint",
    "format": "prettier --write .",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "test:integration": "vitest run --config vitest.integration.config.ts",
    "db:push": "drizzle-kit generate && drizzle-kit migrate",
    "android": "expo start --android",
    "ios": "expo start --ios",
    "qr": "node scripts/generate_qr.mjs",
    "seed:superadmin": "node scripts/seed-superadmin.mjs",
    "verify:superadmin": "node scripts/verify-superadmin.mjs",
    "vps:probe": "bash scripts/vps-probe.sh",
    "eas:ios:preview": "eas build --platform ios --profile preview",
    "eas:ios:production": "eas build --platform ios --profile production",
    "eas:ios:simulator": "eas build --platform ios --profile simulator"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.1045.0",
    "@aws-sdk/s3-request-presigner": "^3.1045.0",
    "@expo/vector-icons": "^15.1.1",
    "@react-native-async-storage/async-storage": "^2.2.0",
    "@react-native-community/netinfo": "^11.5.2",
    "@react-navigation/bottom-tabs": "^7.15.13",
    "@react-navigation/elements": "^2.9.17",
    "@react-navigation/native": "^7.2.4",
    "@tanstack/react-query": "^5.100.9",
    "@trpc/client": "^11.17.0",
    "@trpc/react-query": "^11.17.0",
    "@trpc/server": "^11.17.0",
    "axios": "^1.16.0",
    "clsx": "^2.1.1",
    "cookie": "^1.1.1",
    "dotenv": "^16.6.1",
    "drizzle-orm": "^0.45.2",
    "expo": "~54.0.34",
    "expo-audio": "~1.1.1",
    "expo-build-properties": "^1.0.10",
    "expo-constants": "~18.0.13",
    "expo-device": "^8.0.10",
    "expo-document-picker": "^14.0.8",
    "expo-font": "~14.0.11",
    "expo-haptics": "~15.0.8",
    "expo-image": "~3.0.11",
    "expo-image-picker": "^17.0.11",
    "expo-keep-awake": "~15.0.8",
    "expo-linking": "~8.0.12",
    "expo-location": "^19.0.8",
    "expo-notifications": "~0.32.17",
    "expo-router": "~6.0.23",
    "expo-secure-store": "~15.0.8",
    "expo-sharing": "^14.0.8",
    "expo-splash-screen": "~31.0.13",
    "expo-status-bar": "~3.0.9",
    "expo-symbols": "~1.0.8",
    "expo-system-ui": "~6.0.9",
    "expo-task-manager": "^14.0.9",
    "expo-video": "~3.0.16",
    "expo-web-browser": "~15.0.11",
    "express": "^4.22.1",
    "express-rate-limit": "^7.5.1",
    "ioredis": "^5.10.1",
    "jose": "6.1.0",
    "mysql2": "^3.22.3",
    "nativewind": "^4.2.3",
    "postgres": "^3.4.9",
    "react": "19.1.0",
    "react-dom": "19.1.0",
    "react-native": "0.81.5",
    "react-native-gesture-handler": "~2.28.0",
    "react-native-reanimated": "~4.1.7",
    "react-native-safe-area-context": "~5.6.2",
    "react-native-screens": "~4.16.0",
    "react-native-svg": "15.12.1",
    "react-native-web": "~0.21.2",
    "react-native-worklets": "0.5.1",
    "superjson": "^1.13.3",
    "tailwind-merge": "^2.6.1",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@expo/ngrok": "^4.1.3",
    "@testcontainers/postgresql": "^11.14.0",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/cookie": "^0.6.0",
    "@types/express": "^4.17.25",
    "@types/node": "^22.19.18",
    "@types/qrcode": "^1.5.6",
    "@types/react": "~19.1.17",
    "@vitest/coverage-v8": "^2.1.9",
    "concurrently": "^9.2.1",
    "cross-env": "^7.0.3",
    "drizzle-kit": "^0.31.10",
    "eas-cli": "^16.32.0",
    "esbuild": "^0.25.12",
    "eslint": "^9.39.4",
    "eslint-config-expo": "~10.0.0",
    "happy-dom": "^20.9.0",
    "prettier": "^3.8.3",
    "qrcode": "^1.5.4",
    "tailwindcss": "^3.4.19",
    "testcontainers": "^11.14.0",
    "tsx": "^4.21.0",
    "typescript": "~5.9.3",
    "vitest": "^4.1.8"
  },
  "packageManager": "pnpm@9.12.0",
  "pnpm": {
    "overrides": {
      "undici@<6.24.0": "^6.24.0",
      "qs@<6.14.2": "^6.14.2",
      "tar@<7.5.11": "^7.5.11",
      "postcss@<8.5.10": "^8.5.10",
      "ajv@>=6 <6.14.0": "^6.14.0",
      "ajv@>=8 <8.18.0": "^8.18.0",
      "minimatch@>=3 <3.1.4": "^3.1.4",
      "minimatch@>=4 <5.1.8": "^5.1.8",
      "minimatch@>=9 <9.0.7": "^9.0.7",
      "minimatch@>=10 <10.2.3": "^10.2.3",
      "picomatch@>=2 <2.3.2": "^2.3.2",
      "picomatch@>=4 <4.0.4": "^4.0.4",
      "brace-expansion@>=1 <1.1.13": "^1.1.13",
      "brace-expansion@>=2 <2.0.3": "^2.0.3",
      "vite@<6.4.2": "^6.4.2",
      "esbuild@<0.25.0": "^0.25.0",
      "follow-redirects@<1.16.0": "^1.16.0",
      "node-forge@<1.4.0": "^1.4.0",
      "path-to-regexp@<0.1.13": "^0.1.13",
      "yaml@<2.8.3": "^2.8.3",
      "flatted@<3.4.2": "^3.4.2",
      "rollup@<4.59.0": "^4.59.0",
      "@xmldom/xmldom@<0.8.13": "^0.8.13",
      "@isaacs/brace-expansion@<5.0.1": "^5.0.1",
      "uuid": "^14.0.0",
      "diff@<8.0.3": "^8.0.3"
    }
  },
  "engines": {
    "node": ">=22.0.0"
  }
}
