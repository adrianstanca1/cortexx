# CortexBuild Ultimate — Environment Variables
# Copy this file to .env.local and fill in your values

# API Backend (Express server)
VITE_API_BASE_URL=http://localhost:3001

# Optional: WebSocket base if not same host as Vite (e.g. ws://localhost:3001 or wss://api.example.com)
# VITE_WS_URL=

# Optional: enable mock data fallback when backend is unavailable
# VITE_USE_MOCK_DATA=true

# -----------------------------------------------------------------------------
# Vercel / previews — do NOT use Supabase Auth for this codebase
# -----------------------------------------------------------------------------
# If the browser opens https://*.supabase.co/auth/v1/authorize (GitHub, etc.)
# and fails with ERR_NAME_NOT_RESOLVED, the deployment is still using an old
# bundle or leftover env vars from a removed Supabase project.
#
# Fix:
# 1) Vercel → Settings → Environment Variables: remove every VITE_SUPABASE_*,
#    NEXT_PUBLIC_SUPABASE_*, SUPABASE_* (and redeploy all environments).
# 2) Connect the project to this repo and redeploy so the SPA uses /api only.
# 3) Sign-in uses Google / Microsoft OAuth via your API (Passport) or email/password.
#    Optional OAuth API host for local dev: VITE_OAUTH_API_ORIGIN=http://localhost:3001
#
# Optional (Vercel serverless helpers under server/api/auth/*):
# VERCEL_ALLOWED_ORIGINS=https://your-app.vercel.app
# ALLOW_VERCEL_PREVIEW_SUBDOMAINS=1   # allow any https://*.vercel.app (dev only)

# -----------------------------------------------------------------------------
# Docker Compose — postgres / redis are external (shared cortexbuild-postgres
# container on :55432 host / :5432 inside docker). docker-compose.yml loads
# these via env_file: .env, so they must be defined here (in .env, not VCS).
# -----------------------------------------------------------------------------
POSTGRES_USER=cortexbuild
POSTGRES_PASSWORD=  # 48-char hex; ask the operator or read from the running cortexbuild-postgres container env
POSTGRES_DB=cortexbuild
DATABASE_URL=postgresql://cortexbuild:${POSTGRES_PASSWORD}@cortexbuild-postgres:5432/cortexbuild?sslmode=disable
