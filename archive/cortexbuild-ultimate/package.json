{
  "name": "cortexbuild-ultimate",
  "private": true,
  "version": "3.0.0",
  "engines": {
    "node": ">=20"
  },
  "description": "CortexBuild Ultimate — AI-Powered Unified Construction Management Platform for UK Contractors",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "start": "vite preview --host --port 4173",
    "build": "tsc -b && vite build",
    "preview": "vite preview",
    "lint": "eslint src --ext .ts,.tsx",
    "lint:fix": "eslint src --ext .ts,.tsx --fix",
    "typecheck": "tsc --noEmit",
    "test": "NODE_ENV=test vitest run",
    "test:watch": "NODE_ENV=test vitest",
    "test:coverage": "NODE_ENV=test vitest run --coverage",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "test:e2e:headed": "playwright test --headed",
    "verify": "./scripts/pre-commit-check.sh",
    "verify:routes": "./scripts/verify-server-routes.sh",
    "verify:all": "./scripts/verify-server-routes.sh && ./scripts/pre-commit-check.sh",
    "precommit": "./scripts/pre-commit-check.sh",
    "check": "npm run typecheck && npm run lint && npm test",
    "all": "npm run check && npm run verify:all && npm run server:build && npm run test:coverage",
    "prepare": "husky",
    "db:migrate": "cd server && npm run db:migrate",
    "db:reset": "cd server && npm run db:reset:local",
    "server:dev": "cd server && npm run dev",
    "local:api": "bash scripts/start-local-api.sh",
    "local:api:stop": "bash scripts/stop-local-api.sh",
    "dev:local": "bash scripts/dev-with-local-api.sh",
    "doctor:local-api": "bash scripts/diagnose-local-api.sh",
    "doctor": "bash scripts/full-stack-doctor.sh",
    "server:build": "cd server && npm run build",
    "format": "prettier --write \"src/**/*.{ts,tsx,json,css,md}\"",
    "format:check": "prettier --check \"src/**/*.{ts,tsx,json,css,md}\"",
    "postinstall": "patch-package"
  },
  "dependencies": {
    "@capacitor/camera": "^8.2.0",
    "@capacitor/core": "^8.3.3",
    "@capacitor/geolocation": "^8.2.0",
    "@capacitor/haptics": "^8.0.2",
    "@capacitor/ios": "^8.3.0",
    "@capacitor/network": "^8.0.1",
    "@capacitor/push-notifications": "^8.0.4",
    "@dnd-kit/utilities": "^3.2.2",
    "@sendgrid/mail": "^8.1.6",
    "@tailwindcss/postcss": "^4.2.4",
    "@tailwindcss/vite": "^4.2.4",
    "@tanstack/react-query": "^5.100.9",
    "@types/three": "^0.184.0",
    "autoprefixer": "10.5.0",
    "clsx": "^2.1.1",
    "date-fns": "^4.1.0",
    "idb": "^8.0.3",
    "jspdf": "^4.2.1",
    "jspdf-autotable": "^5.0.7",
    "lucide-react": "^1.14.0",
    "nodemailer": "^8.0.7",
    "pg": "^8.20.0",
    "prom-client": "^15.1.3",
    "react": "^19.2.5",
    "react-dom": "^19.2.5",
    "react-router": "^7.14.2",
    "react-router-dom": "^7.14.2",
    "recharts": "^3.8.1",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.5.0",
    "three": "^0.184.0",
    "vite-plugin-pwa": "^1.2.0",
    "web-ifc": "^0.0.77",
    "web-ifc-three": "^0.0.126",
    "web-push": "^3.6.7",
    "workbox-expiration": "^7.4.1",
    "workbox-precaching": "^7.4.0",
    "workbox-routing": "^7.4.0",
    "workbox-strategies": "^7.4.0",
    "workbox-window": "^7.4.0",
    "zod": "^4.4.3",
    "zustand": "^5.0.12"
  },
  "optionalDependencies": {
    "@rolldown/binding-linux-arm64-gnu": "^1.0.0-rc.18"
  },
  "devDependencies": {
    "@capacitor/cli": "^8.3.0",
    "@dnd-kit/core": "^6.3.1",
    "@dnd-kit/sortable": "^10.0.0",
    "@eslint/js": "^9.39.4",
    "@playwright/test": "^1.59.1",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/jspdf": "^1.3.3",
    "@types/nodemailer": "8.0.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@typescript-eslint/eslint-plugin": "^8.59.0",
    "@typescript-eslint/parser": "^8.59.0",
    "@vite-pwa/assets-generator": "^1.0.2",
    "@vitejs/plugin-react": "^5.2.0",
    "daisyui": "^5.5.19",
    "esbuild": "^0.28.0",
    "eslint": "^9.39.4",
    "eslint-plugin-react-hooks": "^5.2.0",
    "fake-indexeddb": "^6.2.5",
    "happy-dom": "^20.9.0",
    "husky": "^9.1.7",
    "jsdom": "^29.1.1",
    "mock-socket": "^9.3.1",
    "patch-package": "^8.0.1",
    "postcss": "^8.5.12",
    "prettier": "^3.8.3",
    "rollup-plugin-visualizer": "^7.0.1",
    "sharp": "^0.34.5",
    "tailwindcss": "^4.2.4",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.59.2",
    "vite": "^8.0.9",
    "vitest": "^3.2.4"
  },
  "lint-staged": {
    "*.{ts,tsx}": [
      "eslint --fix",
      "bash -c 'npx tsc --noEmit'"
    ],
    "*.{js,jsx}": [
      "eslint --fix"
    ],
    "*.{json,css,md}": [
      "prettier --write"
    ]
  },
  "overrides": {
    "web-ifc-three": {
      "three": "^0.184.0"
    },
    "serialize-javascript": "7.0.5"
  },
  "pnpm": {
    "overrides": {
      "@babel/plugin-transform-modules-systemjs": ">=7.29.4",
      "fast-uri": ">=3.1.2"
    }
  }
}
