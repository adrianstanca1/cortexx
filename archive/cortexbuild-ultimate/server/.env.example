# CortexBuild Ultimate - Server Environment Variables
# Copy to .env and fill in values

# Database — use either DATABASE_URL (hosted Postgres) OR discrete vars below (default: local Docker / free self-hosted)
# If both are set, DATABASE_URL wins. For local Docker Compose DB, leave DATABASE_URL unset.
# DATABASE_URL=postgresql://user:pass@host:5432/dbname?sslmode=require
# Force TLS in dev when not using a known host pattern: DATABASE_SSL=true
# Stricter TLS verify (optional): DATABASE_SSL_REJECT_UNAUTHORIZED=true
#
# --- Local API on your machine + DB in docker-compose.local.yml ---
# Published ports: Postgres 127.0.0.1:15432, Redis 127.0.0.1:16379 (see scripts/start-local-api.sh).
# Quick start:  cp server/env.local.template server/.env
# DB_HOST=127.0.0.1
# DB_PORT=15432
# DB_PASSWORD=cortexbuild_local_dev   (compose default; match POSTGRES_PASSWORD if you changed it)
# REDIS_URL=redis://127.0.0.1:16379
#
# --- VPS / single-machine Postgres on default port ---
DB_HOST=localhost
DB_PORT=5432
DB_NAME=cortexbuild
DB_USER=cortexbuild
DB_PASSWORD=your_secure_password_here

# Redis
REDIS_URL=redis://localhost:6379

# Cursor / agent NDJSON debug sink (optional). If NODE_ENV=production locally, set to 1 so
# POST /api/agent-debug is registered for session logging into the repo.
# ENABLE_AGENT_DEBUG_API=1

# Auth & Security
JWT_SECRET=generate_a_secure_random_string_here_min_32_chars
SESSION_SECRET=same_as_jwt_secret_or_different
# Optional: express-session cookie SameSite (default lax).
# SESSION_COOKIE_SAMESITE=lax
# Optional: share auth cookie between apex and www.
# AUTH_TOKEN_COOKIE_DOMAIN=.cortexbuildpro.com
# Production: if Redis errors during JWT blacklist lookup, deny the request (fail closed).
# Set TOKEN_BLACKLIST_FAIL_OPEN=true only to allow logins when Redis is broken (reduces security).
# TOKEN_BLACKLIST_FAIL_OPEN=
FRONTEND_URL=https://www.cortexbuildpro.com
CORS_ORIGIN=https://cortexbuildpro.com,https://www.cortexbuildpro.com

# OAuth - Google (get from console.cloud.google.com)
# Authorized redirect URI must match GOOGLE_CALLBACK_URL exactly.
# Local Docker: use API port so the OAuth session cookie matches the callback host.
# Prefer **localhost** in the URL so it matches what most people paste into Google Console.
# GOOGLE_CALLBACK_URL=http://localhost:3001/api/auth/google/callback
# The SPA passes ?return_origin= so you still land back on your Vite port after sign-in.
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_CALLBACK_URL=https://www.cortexbuildpro.com/api/auth/google/callback

# OAuth - Microsoft (get from portal.azure.com)
MICROSOFT_CLIENT_ID=
MICROSOFT_CLIENT_SECRET=
MICROSOFT_TENANT=common
MICROSOFT_CALLBACK_URL=https://www.cortexbuildpro.com/api/auth/microsoft/callback

# AI / Ollama
OLLAMA_HOST=http://localhost:11434
OLLAMA_MODEL=qwen3.5:latest
EMBEDDING_MODEL=nomic-embed-text

# AI Chat tuning
MAX_CONTEXT_MESSAGES=20
SUMMARY_THRESHOLD=10

# Cloud AI providers (set at least one for /api/ai beyond local Ollama; see server/lib/unified-ai-client-v2.js)
# OPENROUTER_API_KEY=
# GEMINI_API_KEY=

# Feature gates (default: enabled when unset). Set to false, 0, or no to disable.
# FEATURE_AI_AGENTS=
# FEATURE_FILE_UPLOAD=
# FEATURE_RAG_SEARCH=
# FEATURE_EMAIL=
# FEATURE_WEBSOCKET=

# Email (SMTP)
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
EMAIL_FROM=noreply@cortexbuildpro.com

# Redis (Docker uses REDIS_HOST, local uses REDIS_URL)
REDIS_HOST=redis

# Deploy webhook secret
DEPLOY_SECRET=

# Stripe Billing (optional; set to enable subscription billing)
# Get keys from https://dashboard.stripe.com/apikeys
# STRIPE_SECRET_KEY is required for any billing functionality
STRIPE_SECRET_KEY=
# STRIPE_WEBHOOK_SECRET is required for webhook event handling
# Get from https://dashboard.stripe.com/webhooks (create endpoint for /api/billing/webhook)
STRIPE_WEBHOOK_SECRET=
# Stripe Price IDs — create price objects in https://dashboard.stripe.com/prices
# Each plan needs a corresponding STRIPE_PRICE_* env var
STRIPE_PRICE_STARTER=
STRIPE_PRICE_PRO=
STRIPE_PRICE_ENTERPRISE=
# Optional: base URL for Stripe checkout success/cancel redirects
APP_BASE_URL=https://www.cortexbuildpro.com

# APNs (Apple Push Notification Service) — iOS push notifications
# Get credentials from Apple Developer Account → Keys page (https://developer.apple.com/account/resources/authkeys)
# Create a key with "Apple Push Notifications service (APNs)" capability
# Download the .p8 file and base64 encode for APNS_KEY_CONTENTS, OR save locally and use APNS_KEY_PATH
APNS_KEY_ID=
APNS_TEAM_ID=
# Either APNS_KEY_PATH (file path to .p8) OR APNS_KEY_CONTENTS (base64 encoded .p8)
APNS_KEY_PATH=/path/to/AuthKey_XXXXXXXXXX.p8
# APNS_KEY_CONTENTS=base64_encoded_p8_contents_here
APNS_BUNDLE_ID=com.example.app
# Production (true) or Sandbox (false)
APNS_PRODUCTION=true

# Push notification secrets (optional; VAPID for web push)
# Generate with: npx web-push generate-vapid-keys
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_EMAIL=mailto:noreply@cortexbuildpro.com

# Server
PORT=3001
NODE_ENV=production
