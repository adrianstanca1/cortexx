# Copy to server/.env for API on the host (npm run server:dev) talking to Docker Compose DB/Redis.
#   cp server/env.local.template server/.env
#
# Postgres + Redis from: bash scripts/start-local-api.sh  (docker-compose.local.yml)
#   Postgres: 127.0.0.1:15432   Redis: 127.0.0.1:16379

# Leave DATABASE_URL unset (or delete the line) so DB_* below are used.
# DATABASE_URL=

DB_HOST=127.0.0.1
DB_PORT=15432
DB_NAME=cortexbuild
DB_USER=cortexbuild
DB_PASSWORD=cortexbuild_local_dev

REDIS_URL=redis://127.0.0.1:16379

NODE_ENV=development
PORT=3001

JWT_SECRET=replace_with_openssl_rand_hex_32
SESSION_SECRET=replace_with_openssl_rand_hex_32

FRONTEND_URL=http://localhost:5173
CORS_ORIGIN=http://localhost:5173,http://127.0.0.1:5173,http://127.0.0.1:3001

GOOGLE_CALLBACK_URL=http://localhost:3001/api/auth/google/callback
MICROSOFT_CALLBACK_URL=http://localhost:3001/api/auth/microsoft/callback
