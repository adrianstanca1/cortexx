{
  "python.defaultInterpreterPath": "/opt/homebrew/bin/python3.12",
  "window.autoDetectColorScheme": true,
  "git.openRepositoryInParentFolders": "always",
  "cursor.terminal.usePreviewBox": true,
  "cursor.cpp.enablePartialAccepts": true,
  "cursor.composer.shouldChimeAfterChatFinishes": true,
  "cursor.general.glassShowWarningNotifications": true,
  "remote.SSH.remotePlatform": {
    "cortexvps": "linux"
  },
  "cursor.mcp.enabled": true,
  "cursor.tabs.enabled": true,
  "cursor.sentiment.enabled": true,
  "cursor.workspace.enabled": true,
  "cursor.context.clearOnNewConversation": false,
  "cursor.modelFactory.automatedTaskModel": "claude-4-sonnet",
  "cursor.codeCompletion.enableCodeSnippets": true,
  "cursor.docGeneration.enabled": true,
  "cursor.docGeneration.includeReferences": true,
  "editor.inlineSuggest.enabled": true,
  "editor.fontSize": 13,
  "editor.tabSize": 2,
  "editor.formatOnSave": true,
  "editor.defaultFormatter": "esbenp.prettier-vscode",
  "[typescript]": {
    "editor.defaultFormatter": "esbenp.prettier-vscode"
  },
  "[typescriptreact]": {
    "editor.defaultFormatter": "esbenp.prettier-vscode"
  },
  "[javascript]": {
    "editor.defaultFormatter": "esbenp.prettier-vscode"
  },
  "security.workspace.trust.enabled": true,
  "security.workspace.trust.startupPrompt": true,
  "telemetry.telemetryLevel": "off",
  "updates.check": false,
  "git.enableSmartCommit": true,
  "git.conflictDecoration": "dual",
  "diffEditor.ignoreTrimWhitespace": true,
  "files.associations": {
    "*.env.local": "shellscript"
  },
  "terminal.integrated.shellIntegration.enabled": true,
  "terminal.integrated.env.osx": {
    "FIG_NEW_SESSION": "0",
    "PATH": "/opt/homebrew/bin:/opt/homebrew/sbin:/Users/adrianstanca/.local/bin:${env:PATH}"
  },
  "files.watcherExclude": {
    "**/.git/objects/**": true,
    "**/.git/subtree-cache/**": true,
    "**/node_modules/**": true,
    "**/dist/**": true,
    "**/.next/**": true,
    "**/build/**": true,
    "**/.venv/**": true,
    "**/coverage/**": true,
    "**/.turbo/**": true,
    "**/.cache/**": true,
    "**/.pnpm-store/**": true,
    "**/target/**": true,
    "**/.parcel-cache/**": true
  },
  "search.exclude": {
    "**/node_modules": true,
    "**/dist": true,
    "**/.next": true,
    "**/build": true,
    "**/.venv": true,
    "**/coverage": true,
    "**/.turbo": true,
    "**/package-lock.json": true,
    "**/pnpm-lock.yaml": true,
    "**/yarn.lock": true,
    "**/target": true,
    "**/.pnpm-store": true,
    "**/.parcel-cache": true
  },
  "git.autorefresh": false,
  "editor.minimap.enabled": false,
  "editor.smoothScrolling": false,
  "search.followSymlinks": false,
  "search.smartCase": true,
  "files.enableTrash": true,
  "extensions.autoUpdate": false,
  "extensions.autoCheckUpdates": false,
  "workbench.reduceMotion": "on",
  "editor.stickyScroll.enabled": true,
  "editor.linkedEditing": true,
  "editor.suggestSelection": "first",
  "editor.acceptSuggestionOnCommitCharacter": true,
  "editor.wordSeparators": "`~!@#$%^&*()-=+[{]}\\|;:'\",.<>/?",
  "editor.accessibilitySupport": "off",
  "editor.unicodeHighlight.ambiguousCharacters": false,
  "editor.unicodeHighlight.invisibleCharacters": false,
  "typescript.updateImportsOnFileMove.enabled": "always",
  "javascript.updateImportsOnFileMove.enabled": "always",
  "typescript.preferences.importModuleSpecifierEnding": "minimal",
  "typescript.tsserver.maxTsServerMemory": 8192,
  "workbench.editor.limit.enabled": true,
  "workbench.editor.limit.value": 12,
  "workbench.editor.limit.perEditorGroup": true,
  "workbench.editor.closeEmptyGroups": true,
  "workbench.editor.highlightModifiedTabs": true,
  "explorer.autoReveal": false,
  "explorer.confirmDragAndDrop": false,
  "scm.diffDecorations": "all",
  "search.quickOpen.includeSymbols": true,
  "search.useIgnoreFiles": true,
  "search.useGlobalIgnoreFiles": true,
  "terminal.integrated.scrollback": 50000,
  "terminal.integrated.fastScrollSensitivity": 5,
  "terminal.integrated.macOptionIsMeta": true,
  "terminal.integrated.copyOnSelection": false,
  "problems.decorations.enabled": true,
  "task.autoDetect": "on",
  "files.insertFinalNewline": true,
  "files.trimTrailingWhitespace": false,
  "window.newWindowDimensions": "inherit",
  "window.commandCenter": true,
  "git.showInlineOpenFileAction": true,
  "git.timeline.enabled": true
}
