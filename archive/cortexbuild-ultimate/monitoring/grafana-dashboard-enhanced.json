{
  "__inputs": [],
  "annotations": {
    "list": [
      {
        "builtIn": 1,
        "datasource": "-- Grafana --",
        "enable": true,
        "hide": true,
        "iconColor": "rgba(0, 211, 255, 1)",
        "name": "Annotations & Alerts",
        "type": "dashboard"
      }
    ]
  },
  "editable": true,
  "gnetId": null,
  "graphTooltip": 0,
  "id": 1,
  "links": [],
  "panels": [
    {
      "title": "HTTP Request Rate",
      "type": "graph",
      "datasource": "Prometheus",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 0 },
      "targets": [
        {
          "expr": "rate(http_request_duration_seconds_count[5m])",
          "legendFormat": "{{method}} {{route}}",
          "refId": "A"
        }
      ],
      "yaxes": [
        { "format": "reqps", "label": "Requests/sec" },
        { "format": "short" }
      ],
      "thresholds": []
    },
    {
      "title": "Response Time Percentiles (p50, p95, p99)",
      "type": "graph",
      "datasource": "Prometheus",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 0 },
      "targets": [
        {
          "expr": "histogram_quantile(0.50, rate(http_request_duration_seconds_bucket[5m]))",
          "legendFormat": "p50",
          "refId": "A"
        },
        {
          "expr": "histogram_quantile(0.95, rate(http_request_duration_seconds_bucket[5m]))",
          "legendFormat": "p95",
          "refId": "B"
        },
        {
          "expr": "histogram_quantile(0.99, rate(http_request_duration_seconds_bucket[5m]))",
          "legendFormat": "p99",
          "refId": "C"
        }
      ],
      "yaxes": [
        { "format": "s", "label": "Response Time" },
        { "format": "short" }
      ],
      "thresholds": [
        { "value": 1, "colorMode": "warning", "op": "gt", "line": true },
        { "value": 5, "colorMode": "critical", "op": "gt", "line": true }
      ]
    },
    {
      "title": "Error Rate by Endpoint",
      "type": "graph",
      "datasource": "Prometheus",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 8 },
      "targets": [
        {
          "expr": "rate(http_request_duration_seconds_count{status_code=~\"5..\"}[5m]) / rate(http_request_duration_seconds_count[5m]) * 100",
          "legendFormat": "{{method}} {{route}}",
          "refId": "A"
        }
      ],
      "yaxes": [
        { "format": "percent", "label": "Error %" },
        { "format": "short" }
      ],
      "thresholds": [
        { "value": 5, "colorMode": "warning" },
        { "value": 10, "colorMode": "critical" }
      ]
    },
    {
      "title": "Database Query Latency",
      "type": "graph",
      "datasource": "Prometheus",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 8 },
      "targets": [
        {
          "expr": "rate(pg_stat_activity_count[5m])",
          "legendFormat": "Queries/sec",
          "refId": "A"
        }
      ],
      "yaxes": [
        { "format": "short", "label": "Queries/sec" },
        { "format": "short" }
      ]
    },
    {
      "title": "Database Connection Pool",
      "type": "stat",
      "datasource": "Prometheus",
      "gridPos": { "h": 4, "w": 6, "x": 0, "y": 16 },
      "targets": [
        {
          "expr": "pg_stat_activity_count",
          "legendFormat": "Active Connections",
          "refId": "A"
        }
      ],
      "thresholds": [
        { "value": 80, "colorMode": "warning" },
        { "value": 95, "colorMode": "critical" }
      ]
    },
    {
      "title": "Redis Cache Hit Rate",
      "type": "stat",
      "datasource": "Prometheus",
      "gridPos": { "h": 4, "w": 6, "x": 6, "y": 16 },
      "targets": [
        {
          "expr": "redis_keyspace_hits_total / (redis_keyspace_hits_total + redis_keyspace_misses_total) * 100",
          "legendFormat": "Hit Rate %",
          "refId": "A"
        }
      ],
      "thresholds": [
        { "value": 80, "colorMode": "ok" },
        { "value": 50, "colorMode": "warning" },
        { "value": 20, "colorMode": "critical" }
      ]
    },
    {
      "title": "Memory Usage",
      "type": "graph",
      "datasource": "Prometheus",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 16 },
      "targets": [
        {
          "expr": "process_resident_memory_bytes",
          "legendFormat": "RSS Memory",
          "refId": "A"
        }
      ],
      "yaxes": [{ "format": "bytes", "label": "Memory" }, { "format": "short" }]
    },
    {
      "title": "System Health",
      "type": "stat",
      "datasource": "Prometheus",
      "gridPos": { "h": 4, "w": 6, "x": 0, "y": 20 },
      "targets": [
        {
          "expr": "up",
          "legendFormat": "{{instance}}",
          "refId": "A"
        }
      ],
      "thresholds": [{ "value": 1, "colorMode": "ok" }],
      "colorMode": "background"
    },
    {
      "title": "API Uptime",
      "type": "stat",
      "datasource": "Prometheus",
      "gridPos": { "h": 4, "w": 6, "x": 6, "y": 20 },
      "targets": [
        {
          "expr": "(time() - process_start_time_seconds) / 3600",
          "legendFormat": "Hours",
          "refId": "A"
        }
      ],
      "unit": "h",
      "colorMode": "value"
    }
  ],
  "refresh": "15s",
  "schemaVersion": 27,
  "style": "dark",
  "tags": ["cortexbuild", "api", "monitoring"],
  "templating": { "list": [] },
  "time": { "from": "now-6h", "to": "now" },
  "timepicker": {},
  "timezone": "",
  "title": "CortexBuild Ultimate - Enhanced Dashboard",
  "uid": "cortexbuild-enhanced",
  "version": 1
}
