{
  "name": "@cortexbuild/api",
  "version": "2.0.0",
  "private": true,
  "description": "Unified API \u2014 merged from Ultimate, Field, BuildTrack, Web backends",
  "type": "module",
  "main": "./dist/server.js",
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "build": "tsc || true",
    "start": "NODE_ENV=production node dist/server.js",
    "check": "tsc --noEmit",
    "lint": "eslint src",
    "test": "vitest run --passWithNoTests",
    "db:migrate": "drizzle-kit migrate --config=../db/drizzle.config.ts",
    "db:seed": "tsx src/scripts/seed.ts"
  },
  "dependencies": {
    "@cortexbuild/db": "workspace:*",
    "@cortexbuild/shared": "workspace:*",
    "express": "^4.21.2",
    "cors": "^2.8.5",
    "helmet": "^8.0.0",
    "morgan": "^1.10.0",
    "compression": "^1.7.5",
    "dotenv": "^17.2.2",
    "jsonwebtoken": "^9.0.2",
    "bcryptjs": "^2.4.3",
    "cookie-parser": "^1.4.7",
    "express-rate-limit": "^7.5.0",
    "express-validator": "^7.2.1",
    "multer": "^2.0.0",
    "ioredis": "^5.4.2",
    "pg": "^8.14.0",
    "postgres": "^3.4.5",
    "drizzle-orm": "^0.45.2",
    "drizzle-zod": "^0.7.0",
    "resend": "^4.2.0",
    "ws": "^8.18.0",
    "winston": "^3.17.0",
    "node-cron": "^3.0.3",
    "uuid": "^11.0.5",
    "qrcode": "^1.5.4",
    "@trpc/server": "^11.8.0",
    "zod": "^3.24.0"
  },
  "devDependencies": {
    "typescript": "^5.5.0",
    "tsx": "^4.19.0",
    "vitest": "^3.0.0",
    "@types/express": "^5.0.0",
    "@types/node": "^22.0.0",
    "@types/cors": "^2.8.17",
    "@types/morgan": "^1.9.9",
    "@types/compression": "^1.7.5",
    "@types/jsonwebtoken": "^9.0.9",
    "@types/bcryptjs": "^2.4.6",
    "@types/cookie-parser": "^1.4.8",
    "@types/multer": "^1.4.12",
    "@types/ws": "^8.18.0",
    "@types/node-cron": "^3.0.11",
    "@types/qrcode": "^1.5.5",
    "@types/pg": "^8.11.11",
    "@typescript-eslint/eslint-plugin": "^8.0.0",
    "@typescript-eslint/parser": "^8.0.0",
    "eslint": "^9.0.0"
  }
}