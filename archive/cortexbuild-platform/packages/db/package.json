{
  "name": "@cortexbuild/db",
  "version": "2.0.0",
  "private": true,
  "description": "Unified PostgreSQL schema for all CortexBuild services (Drizzle ORM)",
  "type": "module",
  "main": "./src/index.ts",
  "scripts": {
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "db:push": "drizzle-kit push",
    "db:studio": "drizzle-kit studio",
    "db:check": "drizzle-kit check",
    "build": "tsc",
    "check": "tsc --noEmit"
  },
  "dependencies": {
    "drizzle-orm": "^0.45.2",
    "postgres": "^3.4.5"
  },
  "devDependencies": {
    "drizzle-kit": "^0.31.0",
    "typescript": "^5.5.0",
    "@types/node": "^22.0.0"
  }
}