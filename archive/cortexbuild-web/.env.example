# cortexbuild-web Environment Template
# Copy to .env and fill in your values
# DO NOT commit .env to git

# ─── Database (MySQL 8.0) ─────────────────────────────────────────────────────
# For Docker Compose: mysql://cortexbuild:yourpassword@mysql:3306/cortexbuild
# For local dev:      mysql://root:password@localhost:3306/cortexbuild
DATABASE_URL=mysql://cortexbuild:changeme@mysql:3306/cortexbuild

# MySQL container credentials (used by docker-compose.yml)
MYSQL_ROOT_PASSWORD=your-root-password
MYSQL_DATABASE=cortexbuild
MYSQL_USER=cortexbuild
MYSQL_PASSWORD=your-user-password

# ─── Authentication ───────────────────────────────────────────────────────────
JWT_SECRET=your-jwt-secret-min-32-chars
VITE_APP_ID=your-app-id
OAUTH_SERVER_URL=https://your-oauth-server.com
VITE_OAUTH_PORTAL_URL=https://your-oauth-portal.com
OWNER_OPEN_ID=your-owner-open-id
OWNER_NAME=Adrian Stanca

# ─── WhatsApp Business Cloud API ─────────────────────────────────────────────
WHATSAPP_ACCESS_TOKEN=your-whatsapp-access-token
WHATSAPP_PHONE_NUMBER_ID=your-phone-number-id
WHATSAPP_WEBHOOK_VERIFY_TOKEN=cortexbuild-webhook-verify-token

# ─── AI / Forge API ──────────────────────────────────────────────────────────
BUILT_IN_FORGE_API_KEY=your-forge-api-key
BUILT_IN_FORGE_API_URL=https://your-forge-api.com
VITE_FRONTEND_FORGE_API_KEY=your-frontend-forge-key
VITE_FRONTEND_FORGE_API_URL=https://your-frontend-forge-api.com

# ─── S3 Storage ───────────────────────────────────────────────────────────────
S3_BUCKET=cortexbuild-media
S3_REGION=eu-west-2
S3_ENDPOINT=http://127.0.0.1:9000
S3_ACCESS_KEY_ID=your-s3-access-key
S3_SECRET_ACCESS_KEY=your-s3-secret-key

# ─── Server ───────────────────────────────────────────────────────────────────
NODE_ENV=production
PORT=3000
