{
  "name": "@cortexbuild/server",
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc --noEmit && esbuild src/index.ts --platform=node --packages=external --bundle --format=esm --outfile=dist/index.js",
    "start": "node dist/index.js",
    "lint": "eslint src/**/*.ts",
    "test": "vitest run --passWithNoTests",
    "check": "tsc --noEmit"
  },
  "dependencies": {
    "@trpc/server": "^11.2.2",
    "bcryptjs": "^3.0.2",
    "cors": "^2.8.5",
    "drizzle-orm": "^0.45.2",
    "express": "^5.1.0",
    "express-rate-limit": "^7.5.0",
    "helmet": "^8.1.0",
    "jose": "^6.0.10",
    "morgan": "^1.10.0",
    "postgres": "^3.4.5",
    "superjson": "^2.2.2",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/cors": "^2.8.17",
    "@types/express": "^5.0.2",
    "@types/morgan": "^1.9.9",
    "@types/node": "^22.15.17",
    "drizzle-kit": "^0.31.10",
    "esbuild": "^0.25.4",
    "typescript": "^5.9.3",
    "vitest": "^3.2.0"
  }
}