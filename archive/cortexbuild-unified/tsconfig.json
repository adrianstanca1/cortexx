{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "esModuleInterop": true,
    "allowSyntheticDefaultImports": true,
    "jsx": "react-jsx",
    "strict": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "resolveJsonModule": true,
    "sourceMap": true,
    "baseUrl": ".",
    "paths": {
      "@cortexbuild/shared/*": ["packages/shared/*"],
      "@cortexbuild/server/*": ["packages/server/*"],
      "@cortexbuild/server/routers": ["packages/server/src/routers/index.ts"]
    }
  },
  "include": ["packages/*/src/**/*", "packages/*/*.ts"],
  "exclude": ["node_modules", "dist", ".expo"]
}