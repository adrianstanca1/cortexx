generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// ─── Auth models (NextAuth + Prisma adapter) ───────────────────────────────

model User {
  id                     String                  @id @default(cuid())
  name                   String?
  email                  String                  @unique
  passwordHash           String?
  emailVerified          DateTime?
  image                  String?
  role                   String                  @default("member") // legacy app-level role; per-org role lives on UserOrganization
  totpSecret             String? // encrypted TOTP secret for 2FA
  totpEnabledAt          DateTime?
  totpBackupCodes        Json? // hashed backup codes
  createdAt              DateTime                @default(now())
  updatedAt              DateTime                @updatedAt
  accounts               Account[]
  sessions               Session[]
  pushSubscriptions      PushSubscription[]
  organizations          UserOrganization[]
  notificationPreference NotificationPreference?
  projectBookmarks       ProjectBookmark[]
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

// ─── Domain models ─────────────────────────────────────────────────────────

model Project {
  id                  String           @id @default(cuid())
  name                String
  address             String
  postcode            String
  status              String           @default("active") // active, snagging, quoting, complete
  progress            Int              @default(0)
  clientName          String           @default("")
  shareToken          String?          @unique
  shareTokenExpiresAt DateTime?
  budget              Float            @default(0)
  spent               Float            @default(0)
  lat                 Float            @default(51.5)
  lng                 Float            @default(-0.1)
  startDate           DateTime?
  endDate             DateTime?
  onSiteCount         Int              @default(0)
  archivedAt          DateTime?
  createdAt           DateTime         @default(now())
  updatedAt           DateTime         @updatedAt
  tasks               Task[]
  assignments         Assignment[]
  invoices            Invoice[]
  activities          Activity[]
  timeEntries         TimeEntry[]
  documents           Document[]
  comments            Comment[]
  snags               Snag[]
  rfis                Rfi[]
  announcements       Announcement[]
  observations        Observation[]
  variations          Variation[]
  siteCheckIns        SiteCheckIn[]
  pos                 PurchaseOrder[]
  subInvoices         SubInvoice[]
  drawings            Drawing[]
  milestones          Milestone[]
  permits             Permit[]
  rams                Rams[]
  tenders             Tender[]
  inspections         Inspection[]
  meetings            Meeting[]
  risks               Risk[]
  toolboxTalks        ToolboxTalk[]
  safetyIncidents     SafetyIncident[]

  organizationId  String?
  organization    Organization?     @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  bookmarks       ProjectBookmark[]
  conversations   Conversation[]
  equipmentChecks EquipmentCheck[]

  @@index([status])
  @@index([updatedAt])
  @@index([archivedAt])
  @@index([organizationId])
}

model ProjectBookmark {
  // Per-user pinned-project shortcut. Lightweight join table; users
  // see their bookmarks at the top of /projects and in the dashboard
  // quick-access strip.
  id             String        @id @default(cuid())
  userId         String
  projectId      String
  organizationId String?
  organization   Organization? @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  user           User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  project        Project       @relation(fields: [projectId], references: [id], onDelete: Cascade)
  createdAt      DateTime      @default(now())

  @@unique([userId, projectId])
  @@index([userId])
  @@index([organizationId])
}

model Task {
  id          String      @id @default(cuid())
  title       String
  description String?
  dueDate     DateTime?
  dueTime     String?
  status      String      @default("todo") // todo, in_progress, done
  priority    String      @default("medium") // low, medium, high, critical
  category    String?
  projectId   String?
  assigneeId  String?
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt
  project     Project?    @relation(fields: [projectId], references: [id], onDelete: SetNull)
  assignee    TeamMember? @relation(fields: [assigneeId], references: [id], onDelete: SetNull)
  comments    Comment[]

  organizationId String?
  organization   Organization? @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@index([projectId, status])
  @@index([assigneeId, status])
  @@index([dueDate])
  @@index([status, priority])
  @@index([organizationId])
}

model TeamMember {
  id             String          @id @default(cuid())
  name           String
  role           String
  email          String?
  phone          String?
  avatarColor    String          @default("#2563eb")
  dailyRate      Float           @default(0)
  onSite         Boolean         @default(false)
  createdAt      DateTime        @default(now())
  tasks          Task[]
  assignments    Assignment[]
  timeEntries    TimeEntry[]
  certifications Certification[]
  siteCheckIns   SiteCheckIn[]
  mileageEntries MileageEntry[]

  organizationId String?
  organization   Organization? @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@index([email])
  @@index([organizationId])
}

model Assignment {
  id        String     @id @default(cuid())
  projectId String
  memberId  String
  role      String?
  onSite    Boolean    @default(false)
  project   Project    @relation(fields: [projectId], references: [id], onDelete: Cascade)
  member    TeamMember @relation(fields: [memberId], references: [id], onDelete: Cascade)

  organizationId String?
  organization   Organization? @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@unique([projectId, memberId])
  @@index([organizationId])
}

model Invoice {
  id         String    @id @default(cuid())
  number     String    @unique
  projectId  String?
  clientName String
  amount     Float
  status     String    @default("sent") // draft, sent, paid, overdue
  issuedDate DateTime  @default(now())
  dueDate    DateTime
  paidDate   DateTime?
  notes      String?
  project    Project?  @relation(fields: [projectId], references: [id], onDelete: SetNull)
  createdAt  DateTime  @default(now())

  organizationId String?
  organization   Organization? @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@index([projectId, status])
  @@index([status, dueDate])
  @@index([organizationId])
}

model TimeEntry {
  id        String     @id @default(cuid())
  memberId  String
  projectId String?
  date      DateTime
  hours     Float
  week      Int
  year      Int
  approved  Boolean    @default(false)
  member    TeamMember @relation(fields: [memberId], references: [id], onDelete: Cascade)
  project   Project?   @relation(fields: [projectId], references: [id], onDelete: SetNull)

  organizationId String?
  organization   Organization? @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@index([memberId, date])
  @@index([projectId, date])
  @@index([week, year])
  @@index([organizationId])
}

model Activity {
  id        String   @id @default(cuid())
  projectId String?
  actorName String
  actorType String   @default("human") // human, ai
  action    String
  detail    String?
  iconType  String   @default("check")
  createdAt DateTime @default(now())
  project   Project? @relation(fields: [projectId], references: [id], onDelete: SetNull)

  organizationId String?
  organization   Organization? @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@index([projectId, createdAt])
  @@index([createdAt])
  @@index([organizationId])
  @@index([organizationId, createdAt])
}

model Comment {
  id         String   @id @default(cuid())
  taskId     String?
  projectId  String?
  authorId   String
  authorName String
  body       String
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
  task       Task?    @relation(fields: [taskId], references: [id], onDelete: Cascade)
  project    Project? @relation(fields: [projectId], references: [id], onDelete: SetNull)

  organizationId String?
  organization   Organization? @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@index([taskId, createdAt])
  @@index([projectId, createdAt])
  @@index([organizationId])
}

model Document {
  id        String    @id @default(cuid())
  projectId String?
  type      String // rams, report, photo, receipt, audio
  name      String
  url       String?
  size      Int?
  mimeType  String?
  expiresAt DateTime?
  createdAt DateTime  @default(now())
  project   Project?  @relation(fields: [projectId], references: [id], onDelete: SetNull)

  organizationId String?
  organization   Organization? @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@index([projectId])
  @@index([expiresAt])
  @@index([type])
  @@index([organizationId])
}

model Snag {
  id          String    @id @default(cuid())
  projectId   String
  title       String
  description String?
  location    String?
  status      String    @default("open") // open, in_progress, closed
  priority    String    @default("medium") // low, medium, high, critical
  photoUrl    String?
  dueDate     DateTime?
  closedAt    DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  project     Project   @relation(fields: [projectId], references: [id], onDelete: Cascade)

  organizationId String?
  organization   Organization? @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@index([projectId, status])
  @@index([status, priority])
  @@index([dueDate])
  @@index([organizationId])
}

model Certification {
  id         String          @id @default(cuid())
  memberId   String?
  holderName String
  type       String // CSCS, IPAF, PASMA, asbestos, SSSTS, SMSTS, first aid, etc.
  category   String          @default("qualification") // qualification | training | course | licence | safety
  number     String?
  issuedDate DateTime?
  expiryDate DateTime?
  notes      String?
  createdAt  DateTime        @default(now())
  updatedAt  DateTime        @updatedAt
  member     TeamMember?     @relation(fields: [memberId], references: [id], onDelete: SetNull)
  course     TrainingCourse? @relation(fields: [courseId], references: [id], onDelete: SetNull)
  courseId   String?

  organizationId String?
  organization   Organization? @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@index([memberId])
  @@index([expiryDate])
  @@index([type])
  @@index([category])
  @@index([organizationId])
}

model TrainingCourse {
  id             String          @id @default(cuid())
  name           String
  code           String?
  provider       String?
  category       String          @default("safety") // safety | technical | management | first_aid | environmental | other
  validityDays   Int? // null means non-expiring
  description    String?
  archivedAt     DateTime?
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt
  certifications Certification[]

  organizationId String?
  organization   Organization? @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@index([category])
  @@index([archivedAt])
  @@index([organizationId])
}

model Rfi {
  id          String    @id @default(cuid())
  number      String
  subject     String
  body        String
  projectId   String
  status      String    @default("open") // open, answered, closed
  priority    String    @default("medium") // low, medium, high
  raisedBy    String?
  assignee    String? // freeform: "Structural Engineer", "Architect", etc.
  dueDate     DateTime?
  response    String?
  respondedAt DateTime?
  closedAt    DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  project     Project   @relation(fields: [projectId], references: [id], onDelete: Cascade)

  organizationId String?
  organization   Organization? @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@unique([projectId, number])
  @@index([projectId, status])
  @@index([status, priority])
  @@index([dueDate])
  @@index([organizationId])
}

model Announcement {
  id         String   @id @default(cuid())
  title      String
  body       String
  type       String   @default("general") // general, safety, urgent, update
  projectId  String?
  authorName String?
  isPinned   Boolean  @default(false)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
  project    Project? @relation(fields: [projectId], references: [id], onDelete: SetNull)

  organizationId String?
  organization   Organization? @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@index([projectId, createdAt])
  @@index([isPinned, createdAt])
  @@index([organizationId])
}

model Observation {
  id          String    @id @default(cuid())
  projectId   String
  type        String    @default("positive") // positive, improvement, unsafe, near_miss
  title       String
  description String?
  location    String?
  reportedBy  String?
  photoUrl    String?
  status      String    @default("open") // open, resolved
  resolvedAt  DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  project     Project   @relation(fields: [projectId], references: [id], onDelete: Cascade)

  organizationId String?
  organization   Organization? @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@index([projectId, status])
  @@index([type, status])
  @@index([createdAt])
  @@index([organizationId])
}

model Variation {
  id          String    @id @default(cuid())
  number      String
  projectId   String
  title       String
  description String?
  costImpact  Float     @default(0)
  daysImpact  Int       @default(0)
  status      String    @default("draft") // draft, submitted, approved, rejected
  clientName  String?
  notes       String?
  submittedAt DateTime?
  approvedAt  DateTime?
  rejectedAt  DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  project     Project   @relation(fields: [projectId], references: [id], onDelete: Cascade)

  organizationId String?
  organization   Organization? @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@unique([projectId, number])
  @@index([projectId, status])
  @@index([status])
  @@index([submittedAt])
  @@index([organizationId])
}

model Lead {
  id           String    @id @default(cuid())
  name         String
  contactName  String?
  contactEmail String?
  contactPhone String?
  address      String?
  postcode     String?
  source       String?
  status       String    @default("new") // new, qualified, proposing, won, lost
  value        Float     @default(0)
  notes        String?
  lostReason   String?
  convertedAt  DateTime?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  organizationId String?
  organization   Organization? @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@index([status])
  @@index([createdAt])
  @@index([organizationId])
}

model Customer {
  id           String    @id @default(cuid())
  name         String
  contactName  String?
  contactEmail String?
  contactPhone String?
  address      String?
  postcode     String?
  notes        String?
  archivedAt   DateTime?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
  quotes       Quote[]

  organizationId String?
  organization   Organization? @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@index([name])
  @@index([archivedAt])
  @@index([organizationId])
}

model Quote {
  id           String    @id @default(cuid())
  number       String    @unique
  customerId   String?
  customerName String
  title        String
  description  String?
  lineItems    Json      @default("[]")
  subtotal     Float     @default(0)
  vatRate      Float     @default(20)
  vatAmount    Float     @default(0)
  total        Float     @default(0)
  validUntil   DateTime?
  status       String    @default("draft") // draft, sent, accepted, rejected
  terms        String?
  sentAt       DateTime?
  acceptedAt   DateTime?
  rejectedAt   DateTime?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
  customer     Customer? @relation(fields: [customerId], references: [id], onDelete: SetNull)

  organizationId String?
  organization   Organization? @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@index([status])
  @@index([customerId])
  @@index([validUntil])
  @@index([organizationId])
}

model SiteCheckIn {
  id           String     @id @default(cuid())
  memberId     String
  projectId    String
  checkedInAt  DateTime   @default(now())
  checkedOutAt DateTime?
  latitudeIn   Float?
  longitudeIn  Float?
  latitudeOut  Float?
  longitudeOut Float?
  notes        String?
  member       TeamMember @relation(fields: [memberId], references: [id], onDelete: Cascade)
  project      Project    @relation(fields: [projectId], references: [id], onDelete: Cascade)

  organizationId String?
  organization   Organization? @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@index([memberId, checkedInAt])
  @@index([projectId, checkedInAt])
  @@index([checkedOutAt])
  @@index([organizationId])
}

model MileageEntry {
  id           String      @id @default(cuid())
  memberId     String?
  date         DateTime
  fromAddress  String
  toAddress    String
  fromPostcode String?
  toPostcode   String?
  miles        Float
  vehicleType  String      @default("car") // car, van, motorbike
  purpose      String?
  ratePence    Float       @default(45) // HMRC standard 45p
  amount       Float
  approved     Boolean     @default(false)
  notes        String?
  createdAt    DateTime    @default(now())
  updatedAt    DateTime    @updatedAt
  member       TeamMember? @relation(fields: [memberId], references: [id], onDelete: SetNull)

  organizationId String?
  organization   Organization? @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@index([memberId, date])
  @@index([date])
  @@index([approved])
  @@index([organizationId])
}

model CostItem {
  id          String    @id @default(cuid())
  code        String?
  description String
  category    String?
  unit        String    @default("item") // item, m, m², m³, hour, day, kg, tonne
  unitCost    Float     @default(0)
  vendor      String?
  notes       String?
  archivedAt  DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  organizationId String?
  organization   Organization? @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@index([category])
  @@index([code])
  @@index([archivedAt])
  @@index([organizationId])
}

model Subcontractor {
  id                   String       @id @default(cuid())
  name                 String
  trade                String?
  contactName          String?
  contactEmail         String?
  contactPhone         String?
  address              String?
  postcode             String?
  cisStatus            String       @default("20") // gross, 20, 30
  utrNumber            String?
  insuranceExpiry      DateTime?
  qualificationsExpiry DateTime?
  notes                String?
  archivedAt           DateTime?
  subInvoices          SubInvoice[]
  createdAt            DateTime     @default(now())
  updatedAt            DateTime     @updatedAt

  organizationId String?
  organization   Organization? @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@index([name])
  @@index([trade])
  @@index([insuranceExpiry])
  @@index([archivedAt])
  @@index([organizationId])
}

model Equipment {
  id             String                @id @default(cuid())
  name           String
  code           String?
  category       String?
  serial         String?
  ownership      String                @default("owned") // owned, hired
  hireCompany    String?
  location       String?
  status         String                @default("in_yard") // in_service, in_yard, in_service_centre, out_of_service
  lastServicedAt DateTime?
  nextServiceAt  DateTime?
  notes          String?
  archivedAt     DateTime?
  createdAt      DateTime              @default(now())
  updatedAt      DateTime              @updatedAt
  maintenances   MaintenanceSchedule[]

  organizationId  String?
  organization    Organization?    @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  equipmentChecks EquipmentCheck[]

  @@index([status])
  @@index([nextServiceAt])
  @@index([archivedAt])
  @@index([organizationId])
}

model EquipmentCheck {
  id             String     @id @default(cuid())
  projectId      String?
  project        Project?   @relation(fields: [projectId], references: [id], onDelete: SetNull)
  equipmentId    String?
  equipment      Equipment? @relation(fields: [equipmentId], references: [id], onDelete: SetNull)
  type           String     @default("scissor_lift") // scissor_lift | cherry_picker | telehandler | harness | fall_arrest | ladder | other
  title          String
  status         String     @default("draft") // draft | in_progress | passed | failed
  checklistItems Json       @default("[]")
  overallResult  String? // pass | fail
  conductedBy    String?
  completedAt    DateTime?
  notes          String?
  createdAt      DateTime   @default(now())
  updatedAt      DateTime   @updatedAt

  organizationId String?
  organization   Organization? @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@index([projectId])
  @@index([equipmentId])
  @@index([type])
  @@index([status])
  @@index([organizationId])
}

model Material {
  id           String    @id @default(cuid())
  name         String
  code         String?
  category     String?
  unit         String    @default("item")
  unitCost     Float     @default(0)
  stockLevel   Float     @default(0)
  reorderPoint Float     @default(0)
  supplier     String?
  location     String?
  notes        String?
  archivedAt   DateTime?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  organizationId String?
  organization   Organization? @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@index([category])
  @@index([code])
  @@index([archivedAt])
  @@index([organizationId])
}

model PurchaseOrder {
  id               String    @id @default(cuid())
  number           String    @unique
  projectId        String?
  supplier         String
  contactEmail     String?
  contactPhone     String?
  status           String    @default("draft") // draft, sent, received, closed, cancelled
  lineItems        Json      @default("[]")
  subtotal         Float     @default(0)
  vatRate          Float     @default(20)
  vatAmount        Float     @default(0)
  total            Float     @default(0)
  expectedDelivery DateTime?
  receivedAt       DateTime?
  sentAt           DateTime?
  closedAt         DateTime?
  notes            String?
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt
  project          Project?  @relation(fields: [projectId], references: [id], onDelete: SetNull)

  organizationId String?
  organization   Organization? @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@index([projectId, status])
  @@index([status])
  @@index([expectedDelivery])
  @@index([organizationId])
}

model SubInvoice {
  id              String        @id @default(cuid())
  number          String
  subcontractorId String
  projectId       String?
  invoiceDate     DateTime
  description     String?
  netAmount       Float         @default(0)
  vatAmount       Float         @default(0)
  cisAmount       Float         @default(0)
  grossAmount     Float         @default(0)
  payableAmount   Float         @default(0)
  status          String        @default("received") // received, approved, paid, disputed
  paidAt          DateTime?
  notes           String?
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt
  subcontractor   Subcontractor @relation(fields: [subcontractorId], references: [id], onDelete: Cascade)
  project         Project?      @relation(fields: [projectId], references: [id], onDelete: SetNull)

  organizationId String?
  organization   Organization? @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@unique([subcontractorId, number])
  @@index([subcontractorId, status])
  @@index([status, invoiceDate])
  @@index([organizationId])
}

model Drawing {
  id         String            @id @default(cuid())
  projectId  String
  number     String
  title      String
  discipline String? // architectural, structural, electrical, mechanical, plumbing, civil
  status     String            @default("draft") // draft, approved, superseded, archived
  notes      String?
  archivedAt DateTime?
  createdAt  DateTime          @default(now())
  updatedAt  DateTime          @updatedAt
  project    Project           @relation(fields: [projectId], references: [id], onDelete: Cascade)
  revisions  DrawingRevision[]

  organizationId String?
  organization   Organization? @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@unique([projectId, number])
  @@index([projectId, status])
  @@index([discipline])
  @@index([organizationId])
}

model DrawingRevision {
  id         String   @id @default(cuid())
  drawingId  String
  revision   String // e.g. "A", "B", "P01", "T01"
  fileUrl    String?
  fileName   String?
  fileSize   Int?
