generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─── Auth models (NextAuth + Prisma adapter) ───────────────────────────────

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String    @unique
  passwordHash  String?
  emailVerified DateTime?
  image         String?
  role          String    @default("member") // member, admin
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  accounts      Account[]
  sessions      Session[]
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

// ─── Domain models ─────────────────────────────────────────────────────────

model Project {
  id            String          @id @default(cuid())
  name          String
  address       String
  postcode      String
  status        String          @default("active") // active, snagging, quoting, complete
  progress      Int             @default(0)
  clientName    String          @default("")
  shareToken    String?         @unique
  budget        Float           @default(0)
  spent         Float           @default(0)
  lat           Float           @default(51.5)
  lng           Float           @default(-0.1)
  startDate     DateTime?
  endDate       DateTime?
  onSiteCount   Int             @default(0)
  archivedAt    DateTime?
  createdAt     DateTime        @default(now())
  updatedAt     DateTime        @updatedAt
  tasks         Task[]
  assignments   Assignment[]
  invoices      Invoice[]
  activities    Activity[]
  timeEntries   TimeEntry[]
  documents     Document[]
  comments      Comment[]
  snags         Snag[]
  rfis          Rfi[]
  announcements Announcement[]
  observations  Observation[]
  variations    Variation[]
  siteCheckIns  SiteCheckIn[]
  pos           PurchaseOrder[]
  subInvoices   SubInvoice[]

  @@index([status])
  @@index([updatedAt])
  @@index([archivedAt])
}

model Task {
  id          String      @id @default(cuid())
  title       String
  description String?
  dueDate     DateTime?
  dueTime     String?
  status      String      @default("todo") // todo, in_progress, done
  priority    String      @default("medium") // low, medium, high, critical
  category    String?
  projectId   String?
  assigneeId  String?
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt
  project     Project?    @relation(fields: [projectId], references: [id], onDelete: SetNull)
  assignee    TeamMember? @relation(fields: [assigneeId], references: [id], onDelete: SetNull)
  comments    Comment[]

  @@index([projectId, status])
  @@index([assigneeId, status])
  @@index([dueDate])
  @@index([status, priority])
}

model TeamMember {
  id             String          @id @default(cuid())
  name           String
  role           String
  email          String?
  phone          String?
  avatarColor    String          @default("#2563eb")
  dailyRate      Float           @default(0)
  onSite         Boolean         @default(false)
  createdAt      DateTime        @default(now())
  tasks          Task[]
  assignments    Assignment[]
  timeEntries    TimeEntry[]
  certifications Certification[]
  siteCheckIns   SiteCheckIn[]
  mileageEntries MileageEntry[]

  @@index([email])
}

model Assignment {
  id        String     @id @default(cuid())
  projectId String
  memberId  String
  role      String?
  onSite    Boolean    @default(false)
  project   Project    @relation(fields: [projectId], references: [id], onDelete: Cascade)
  member    TeamMember @relation(fields: [memberId], references: [id], onDelete: Cascade)

  @@unique([projectId, memberId])
}

model Invoice {
  id         String    @id @default(cuid())
  number     String    @unique
  projectId  String?
  clientName String
  amount     Float
  status     String    @default("sent") // draft, sent, paid, overdue
  issuedDate DateTime  @default(now())
  dueDate    DateTime
  paidDate   DateTime?
  notes      String?
  project    Project?  @relation(fields: [projectId], references: [id], onDelete: SetNull)
  createdAt  DateTime  @default(now())

  @@index([projectId, status])
  @@index([status, dueDate])
}

model TimeEntry {
  id        String     @id @default(cuid())
  memberId  String
  projectId String?
  date      DateTime
  hours     Float
  week      Int
  year      Int
  approved  Boolean    @default(false)
  member    TeamMember @relation(fields: [memberId], references: [id], onDelete: Cascade)
  project   Project?   @relation(fields: [projectId], references: [id], onDelete: SetNull)

  @@index([memberId, date])
  @@index([projectId, date])
  @@index([week, year])
}

model Activity {
  id        String   @id @default(cuid())
  projectId String?
  actorName String
  actorType String   @default("human") // human, ai
  action    String
  detail    String?
  iconType  String   @default("check")
  createdAt DateTime @default(now())
  project   Project? @relation(fields: [projectId], references: [id], onDelete: SetNull)

  @@index([projectId, createdAt])
  @@index([createdAt])
}

model Comment {
  id         String   @id @default(cuid())
  taskId     String?
  projectId  String?
  authorId   String
  authorName String
  body       String
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
  task       Task?    @relation(fields: [taskId], references: [id], onDelete: Cascade)
  project    Project? @relation(fields: [projectId], references: [id], onDelete: SetNull)

  @@index([taskId, createdAt])
  @@index([projectId, createdAt])
}

model Document {
  id        String    @id @default(cuid())
  projectId String?
  type      String // rams, report, photo, receipt, audio
  name      String
  url       String?
  size      Int?
  mimeType  String?
  expiresAt DateTime?
  createdAt DateTime  @default(now())
  project   Project?  @relation(fields: [projectId], references: [id], onDelete: SetNull)

  @@index([projectId])
  @@index([expiresAt])
  @@index([type])
}

model Snag {
  id          String    @id @default(cuid())
  projectId   String
  title       String
  description String?
  location    String?
  status      String    @default("open") // open, in_progress, closed
  priority    String    @default("medium") // low, medium, high, critical
  photoUrl    String?
  dueDate     DateTime?
  closedAt    DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  project     Project   @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@index([projectId, status])
  @@index([status, priority])
  @@index([dueDate])
}

model Certification {
  id         String      @id @default(cuid())
  memberId   String?
  holderName String
  type       String // CSCS, IPAF, PASMA, asbestos, SSSTS, SMSTS, first aid, etc.
  number     String?
  issuedDate DateTime?
  expiryDate DateTime?
  notes      String?
  createdAt  DateTime    @default(now())
  updatedAt  DateTime    @updatedAt
  member     TeamMember? @relation(fields: [memberId], references: [id], onDelete: SetNull)

  @@index([memberId])
  @@index([expiryDate])
  @@index([type])
}

model Rfi {
  id          String    @id @default(cuid())
  number      String
  subject     String
  body        String
  projectId   String
  status      String    @default("open") // open, answered, closed
  priority    String    @default("medium") // low, medium, high
  raisedBy    String?
  assignee    String? // freeform: "Structural Engineer", "Architect", etc.
  dueDate     DateTime?
  response    String?
  respondedAt DateTime?
  closedAt    DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  project     Project   @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@unique([projectId, number])
  @@index([projectId, status])
  @@index([status, priority])
  @@index([dueDate])
}

model Announcement {
  id         String   @id @default(cuid())
  title      String
  body       String
  type       String   @default("general") // general, safety, urgent, update
  projectId  String?
  authorName String?
  isPinned   Boolean  @default(false)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
  project    Project? @relation(fields: [projectId], references: [id], onDelete: SetNull)

  @@index([projectId, createdAt])
  @@index([isPinned, createdAt])
}

model Observation {
  id          String    @id @default(cuid())
  projectId   String
  type        String    @default("positive") // positive, improvement, unsafe, near_miss
  title       String
  description String?
  location    String?
  reportedBy  String?
  photoUrl    String?
  status      String    @default("open") // open, resolved
  resolvedAt  DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  project     Project   @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@index([projectId, status])
  @@index([type, status])
  @@index([createdAt])
}

model Variation {
  id          String    @id @default(cuid())
  number      String
  projectId   String
  title       String
  description String?
  costImpact  Float     @default(0)
  daysImpact  Int       @default(0)
  status      String    @default("draft") // draft, submitted, approved, rejected
  clientName  String?
  notes       String?
  submittedAt DateTime?
  approvedAt  DateTime?
  rejectedAt  DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  project     Project   @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@unique([projectId, number])
  @@index([projectId, status])
  @@index([status])
  @@index([submittedAt])
}

model Lead {
  id           String    @id @default(cuid())
  name         String
  contactName  String?
  contactEmail String?
  contactPhone String?
  address      String?
  postcode     String?
  source       String?
  status       String    @default("new") // new, qualified, proposing, won, lost
  value        Float     @default(0)
  notes        String?
  lostReason   String?
  convertedAt  DateTime?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  @@index([status])
  @@index([createdAt])
}

model Customer {
  id           String    @id @default(cuid())
  name         String
  contactName  String?
  contactEmail String?
  contactPhone String?
  address      String?
  postcode     String?
  notes        String?
  archivedAt   DateTime?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
  quotes       Quote[]

  @@index([name])
  @@index([archivedAt])
}

model Quote {
  id           String    @id @default(cuid())
  number       String    @unique
  customerId   String?
  customerName String
  title        String
  description  String?
  lineItems    Json      @default("[]")
  subtotal     Float     @default(0)
  vatRate      Float     @default(20)
  vatAmount    Float     @default(0)
  total        Float     @default(0)
  validUntil   DateTime?
  status       String    @default("draft") // draft, sent, accepted, rejected
  terms        String?
  sentAt       DateTime?
  acceptedAt   DateTime?
  rejectedAt   DateTime?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
  customer     Customer? @relation(fields: [customerId], references: [id], onDelete: SetNull)

  @@index([status])
  @@index([customerId])
  @@index([validUntil])
}

model SiteCheckIn {
  id           String     @id @default(cuid())
  memberId     String
  projectId    String
  checkedInAt  DateTime   @default(now())
  checkedOutAt DateTime?
  latitudeIn   Float?
  longitudeIn  Float?
  latitudeOut  Float?
  longitudeOut Float?
  notes        String?
  member       TeamMember @relation(fields: [memberId], references: [id], onDelete: Cascade)
  project      Project    @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@index([memberId, checkedInAt])
  @@index([projectId, checkedInAt])
  @@index([checkedOutAt])
}

model MileageEntry {
  id           String      @id @default(cuid())
  memberId     String?
  date         DateTime
  fromAddress  String
  toAddress    String
  fromPostcode String?
  toPostcode   String?
  miles        Float
  vehicleType  String      @default("car") // car, van, motorbike
  purpose      String?
  ratePence    Float       @default(45) // HMRC standard 45p
  amount       Float
  approved     Boolean     @default(false)
  notes        String?
  createdAt    DateTime    @default(now())
  updatedAt    DateTime    @updatedAt
  member       TeamMember? @relation(fields: [memberId], references: [id], onDelete: SetNull)

  @@index([memberId, date])
  @@index([date])
  @@index([approved])
}

model CostItem {
  id          String    @id @default(cuid())
  code        String?
  description String
  category    String?
  unit        String    @default("item") // item, m, m², m³, hour, day, kg, tonne
  unitCost    Float     @default(0)
  vendor      String?
  notes       String?
  archivedAt  DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@index([category])
  @@index([code])
  @@index([archivedAt])
}

model Subcontractor {
  id                   String       @id @default(cuid())
  name                 String
  trade                String?
  contactName          String?
  contactEmail         String?
  contactPhone         String?
  address              String?
  postcode             String?
  cisStatus            String       @default("20") // gross, 20, 30
  utrNumber            String?
  insuranceExpiry      DateTime?
  qualificationsExpiry DateTime?
  notes                String?
  archivedAt           DateTime?
  subInvoices          SubInvoice[]
  createdAt            DateTime     @default(now())
  updatedAt            DateTime     @updatedAt

  @@index([name])
  @@index([trade])
  @@index([insuranceExpiry])
  @@index([archivedAt])
}

model Equipment {
  id             String    @id @default(cuid())
  name           String
  code           String?
  category       String?
  serial         String?
  ownership      String    @default("owned") // owned, hired
  hireCompany    String?
  location       String?
  status         String    @default("in_yard") // in_service, in_yard, in_service_centre, out_of_service
  lastServicedAt DateTime?
  nextServiceAt  DateTime?
  notes          String?
  archivedAt     DateTime?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  @@index([status])
  @@index([nextServiceAt])
  @@index([archivedAt])
}

model Material {
  id           String    @id @default(cuid())
  name         String
  code         String?
  category     String?
  unit         String    @default("item")
  unitCost     Float     @default(0)
  stockLevel   Float     @default(0)
  reorderPoint Float     @default(0)
  supplier     String?
  location     String?
  notes        String?
  archivedAt   DateTime?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  @@index([category])
  @@index([code])
  @@index([archivedAt])
}

model PurchaseOrder {
  id               String    @id @default(cuid())
  number           String    @unique
  projectId        String?
  supplier         String
  contactEmail     String?
  contactPhone     String?
  status           String    @default("draft") // draft, sent, received, closed, cancelled
  lineItems        Json      @default("[]")
  subtotal         Float     @default(0)
  vatRate          Float     @default(20)
  vatAmount        Float     @default(0)
  total            Float     @default(0)
  expectedDelivery DateTime?
  receivedAt       DateTime?
  sentAt           DateTime?
  closedAt         DateTime?
  notes            String?
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt
  project          Project?  @relation(fields: [projectId], references: [id], onDelete: SetNull)

  @@index([projectId, status])
  @@index([status])
  @@index([expectedDelivery])
}

model SubInvoice {
  id              String        @id @default(cuid())
  number          String
  subcontractorId String
  projectId       String?
  invoiceDate     DateTime
  description     String?
  netAmount       Float         @default(0)
  vatAmount       Float         @default(0)
  cisAmount       Float         @default(0)
  grossAmount     Float         @default(0)
  payableAmount   Float         @default(0)
  status          String        @default("received") // received, approved, paid, disputed
  paidAt          DateTime?
  notes           String?
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt
  subcontractor   Subcontractor @relation(fields: [subcontractorId], references: [id], onDelete: Cascade)
  project         Project?      @relation(fields: [projectId], references: [id], onDelete: SetNull)

  @@unique([subcontractorId, number])
  @@index([subcontractorId, status])
  @@index([status, invoiceDate])
}
