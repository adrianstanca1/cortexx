generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─── Auth models (NextAuth + Prisma adapter) ───────────────────────────────

model User {
  id                     String                  @id @default(cuid())
  name                   String?
  email                  String                  @unique
  passwordHash           String?
  emailVerified          DateTime?
  image                  String?
  role                   String                  @default("member") // legacy app-level role; per-org role lives on UserOrganization
  totpSecret             String? // encrypted TOTP secret for 2FA
  totpEnabledAt          DateTime?
  totpBackupCodes        Json? // hashed backup codes
  createdAt              DateTime                @default(now())
  updatedAt              DateTime                @updatedAt
  accounts               Account[]
  sessions               Session[]
  pushSubscriptions      PushSubscription[]
  organizations          UserOrganization[]
  notificationPreference NotificationPreference?
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

// ─── Domain models ─────────────────────────────────────────────────────────

model Project {
  id              String           @id @default(cuid())
  name            String
  address         String
  postcode        String
  status          String           @default("active") // active, snagging, quoting, complete
  progress        Int              @default(0)
  clientName      String           @default("")
  shareToken      String?          @unique
  budget          Float            @default(0)
  spent           Float            @default(0)
  lat             Float            @default(51.5)
  lng             Float            @default(-0.1)
  startDate       DateTime?
  endDate         DateTime?
  onSiteCount     Int              @default(0)
  archivedAt      DateTime?
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt
  tasks           Task[]
  assignments     Assignment[]
  invoices        Invoice[]
  activities      Activity[]
  timeEntries     TimeEntry[]
  documents       Document[]
  comments        Comment[]
  snags           Snag[]
  rfis            Rfi[]
  announcements   Announcement[]
  observations    Observation[]
  variations      Variation[]
  siteCheckIns    SiteCheckIn[]
  pos             PurchaseOrder[]
  subInvoices     SubInvoice[]
  drawings        Drawing[]
  milestones      Milestone[]
  permits         Permit[]
  rams            Rams[]
  tenders         Tender[]
  inspections     Inspection[]
  meetings        Meeting[]
  risks           Risk[]
  toolboxTalks    ToolboxTalk[]
  safetyIncidents SafetyIncident[]

  @@index([status])
  @@index([updatedAt])
  @@index([archivedAt])
}

model Task {
  id          String      @id @default(cuid())
  title       String
  description String?
  dueDate     DateTime?
  dueTime     String?
  status      String      @default("todo") // todo, in_progress, done
  priority    String      @default("medium") // low, medium, high, critical
  category    String?
  projectId   String?
  assigneeId  String?
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt
  project     Project?    @relation(fields: [projectId], references: [id], onDelete: SetNull)
  assignee    TeamMember? @relation(fields: [assigneeId], references: [id], onDelete: SetNull)
  comments    Comment[]

  @@index([projectId, status])
  @@index([assigneeId, status])
  @@index([dueDate])
  @@index([status, priority])
}

model TeamMember {
  id             String          @id @default(cuid())
  name           String
  role           String
  email          String?
  phone          String?
  avatarColor    String          @default("#2563eb")
  dailyRate      Float           @default(0)
  onSite         Boolean         @default(false)
  createdAt      DateTime        @default(now())
  tasks          Task[]
  assignments    Assignment[]
  timeEntries    TimeEntry[]
  certifications Certification[]
  siteCheckIns   SiteCheckIn[]
  mileageEntries MileageEntry[]

  @@index([email])
}

model Assignment {
  id        String     @id @default(cuid())
  projectId String
  memberId  String
  role      String?
  onSite    Boolean    @default(false)
  project   Project    @relation(fields: [projectId], references: [id], onDelete: Cascade)
  member    TeamMember @relation(fields: [memberId], references: [id], onDelete: Cascade)

  @@unique([projectId, memberId])
}

model Invoice {
  id         String    @id @default(cuid())
  number     String    @unique
  projectId  String?
  clientName String
  amount     Float
  status     String    @default("sent") // draft, sent, paid, overdue
  issuedDate DateTime  @default(now())
  dueDate    DateTime
  paidDate   DateTime?
  notes      String?
  project    Project?  @relation(fields: [projectId], references: [id], onDelete: SetNull)
  createdAt  DateTime  @default(now())

  @@index([projectId, status])
  @@index([status, dueDate])
}

model TimeEntry {
  id        String     @id @default(cuid())
  memberId  String
  projectId String?
  date      DateTime
  hours     Float
  week      Int
  year      Int
  approved  Boolean    @default(false)
  member    TeamMember @relation(fields: [memberId], references: [id], onDelete: Cascade)
  project   Project?   @relation(fields: [projectId], references: [id], onDelete: SetNull)

  @@index([memberId, date])
  @@index([projectId, date])
  @@index([week, year])
}

model Activity {
  id        String   @id @default(cuid())
  projectId String?
  actorName String
  actorType String   @default("human") // human, ai
  action    String
  detail    String?
  iconType  String   @default("check")
  createdAt DateTime @default(now())
  project   Project? @relation(fields: [projectId], references: [id], onDelete: SetNull)

  @@index([projectId, createdAt])
  @@index([createdAt])
}

model Comment {
  id         String   @id @default(cuid())
  taskId     String?
  projectId  String?
  authorId   String
  authorName String
  body       String
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
  task       Task?    @relation(fields: [taskId], references: [id], onDelete: Cascade)
  project    Project? @relation(fields: [projectId], references: [id], onDelete: SetNull)

  @@index([taskId, createdAt])
  @@index([projectId, createdAt])
}

model Document {
  id        String    @id @default(cuid())
  projectId String?
  type      String // rams, report, photo, receipt, audio
  name      String
  url       String?
  size      Int?
  mimeType  String?
  expiresAt DateTime?
  createdAt DateTime  @default(now())
  project   Project?  @relation(fields: [projectId], references: [id], onDelete: SetNull)

  @@index([projectId])
  @@index([expiresAt])
  @@index([type])
}

model Snag {
  id          String    @id @default(cuid())
  projectId   String
  title       String
  description String?
  location    String?
  status      String    @default("open") // open, in_progress, closed
  priority    String    @default("medium") // low, medium, high, critical
  photoUrl    String?
  dueDate     DateTime?
  closedAt    DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  project     Project   @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@index([projectId, status])
  @@index([status, priority])
  @@index([dueDate])
}

model Certification {
  id         String      @id @default(cuid())
  memberId   String?
  holderName String
  type       String // CSCS, IPAF, PASMA, asbestos, SSSTS, SMSTS, first aid, etc.
  number     String?
  issuedDate DateTime?
  expiryDate DateTime?
  notes      String?
  createdAt  DateTime    @default(now())
  updatedAt  DateTime    @updatedAt
  member     TeamMember? @relation(fields: [memberId], references: [id], onDelete: SetNull)

  @@index([memberId])
  @@index([expiryDate])
  @@index([type])
}

model Rfi {
  id          String    @id @default(cuid())
  number      String
  subject     String
  body        String
  projectId   String
  status      String    @default("open") // open, answered, closed
  priority    String    @default("medium") // low, medium, high
  raisedBy    String?
  assignee    String? // freeform: "Structural Engineer", "Architect", etc.
  dueDate     DateTime?
  response    String?
  respondedAt DateTime?
  closedAt    DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  project     Project   @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@unique([projectId, number])
  @@index([projectId, status])
  @@index([status, priority])
  @@index([dueDate])
}

model Announcement {
  id         String   @id @default(cuid())
  title      String
  body       String
  type       String   @default("general") // general, safety, urgent, update
  projectId  String?
  authorName String?
  isPinned   Boolean  @default(false)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
  project    Project? @relation(fields: [projectId], references: [id], onDelete: SetNull)

  @@index([projectId, createdAt])
  @@index([isPinned, createdAt])
}

model Observation {
  id          String    @id @default(cuid())
  projectId   String
  type        String    @default("positive") // positive, improvement, unsafe, near_miss
  title       String
  description String?
  location    String?
  reportedBy  String?
  photoUrl    String?
  status      String    @default("open") // open, resolved
  resolvedAt  DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  project     Project   @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@index([projectId, status])
  @@index([type, status])
  @@index([createdAt])
}

model Variation {
  id          String    @id @default(cuid())
  number      String
  projectId   String
  title       String
  description String?
  costImpact  Float     @default(0)
  daysImpact  Int       @default(0)
  status      String    @default("draft") // draft, submitted, approved, rejected
  clientName  String?
  notes       String?
  submittedAt DateTime?
  approvedAt  DateTime?
  rejectedAt  DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  project     Project   @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@unique([projectId, number])
  @@index([projectId, status])
  @@index([status])
  @@index([submittedAt])
}

model Lead {
  id           String    @id @default(cuid())
  name         String
  contactName  String?
  contactEmail String?
  contactPhone String?
  address      String?
  postcode     String?
  source       String?
  status       String    @default("new") // new, qualified, proposing, won, lost
  value        Float     @default(0)
  notes        String?
  lostReason   String?
  convertedAt  DateTime?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  @@index([status])
  @@index([createdAt])
}

model Customer {
  id           String    @id @default(cuid())
  name         String
  contactName  String?
  contactEmail String?
  contactPhone String?
  address      String?
  postcode     String?
  notes        String?
  archivedAt   DateTime?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
  quotes       Quote[]

  @@index([name])
  @@index([archivedAt])
}

model Quote {
  id           String    @id @default(cuid())
  number       String    @unique
  customerId   String?
  customerName String
  title        String
  description  String?
  lineItems    Json      @default("[]")
  subtotal     Float     @default(0)
  vatRate      Float     @default(20)
  vatAmount    Float     @default(0)
  total        Float     @default(0)
  validUntil   DateTime?
  status       String    @default("draft") // draft, sent, accepted, rejected
  terms        String?
  sentAt       DateTime?
  acceptedAt   DateTime?
  rejectedAt   DateTime?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
  customer     Customer? @relation(fields: [customerId], references: [id], onDelete: SetNull)

  @@index([status])
  @@index([customerId])
  @@index([validUntil])
}

model SiteCheckIn {
  id           String     @id @default(cuid())
  memberId     String
  projectId    String
  checkedInAt  DateTime   @default(now())
  checkedOutAt DateTime?
  latitudeIn   Float?
  longitudeIn  Float?
  latitudeOut  Float?
  longitudeOut Float?
  notes        String?
  member       TeamMember @relation(fields: [memberId], references: [id], onDelete: Cascade)
  project      Project    @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@index([memberId, checkedInAt])
  @@index([projectId, checkedInAt])
  @@index([checkedOutAt])
}

model MileageEntry {
  id           String      @id @default(cuid())
  memberId     String?
  date         DateTime
  fromAddress  String
  toAddress    String
  fromPostcode String?
  toPostcode   String?
  miles        Float
  vehicleType  String      @default("car") // car, van, motorbike
  purpose      String?
  ratePence    Float       @default(45) // HMRC standard 45p
  amount       Float
  approved     Boolean     @default(false)
  notes        String?
  createdAt    DateTime    @default(now())
  updatedAt    DateTime    @updatedAt
  member       TeamMember? @relation(fields: [memberId], references: [id], onDelete: SetNull)

  @@index([memberId, date])
  @@index([date])
  @@index([approved])
}

model CostItem {
  id          String    @id @default(cuid())
  code        String?
  description String
  category    String?
  unit        String    @default("item") // item, m, m², m³, hour, day, kg, tonne
  unitCost    Float     @default(0)
  vendor      String?
  notes       String?
  archivedAt  DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@index([category])
  @@index([code])
  @@index([archivedAt])
}

model Subcontractor {
  id                   String       @id @default(cuid())
  name                 String
  trade                String?
  contactName          String?
  contactEmail         String?
  contactPhone         String?
  address              String?
  postcode             String?
  cisStatus            String       @default("20") // gross, 20, 30
  utrNumber            String?
  insuranceExpiry      DateTime?
  qualificationsExpiry DateTime?
  notes                String?
  archivedAt           DateTime?
  subInvoices          SubInvoice[]
  createdAt            DateTime     @default(now())
  updatedAt            DateTime     @updatedAt

  @@index([name])
  @@index([trade])
  @@index([insuranceExpiry])
  @@index([archivedAt])
}

model Equipment {
  id             String                @id @default(cuid())
  name           String
  code           String?
  category       String?
  serial         String?
  ownership      String                @default("owned") // owned, hired
  hireCompany    String?
  location       String?
  status         String                @default("in_yard") // in_service, in_yard, in_service_centre, out_of_service
  lastServicedAt DateTime?
  nextServiceAt  DateTime?
  notes          String?
  archivedAt     DateTime?
  createdAt      DateTime              @default(now())
  updatedAt      DateTime              @updatedAt
  maintenances   MaintenanceSchedule[]

  @@index([status])
  @@index([nextServiceAt])
  @@index([archivedAt])
}

model Material {
  id           String    @id @default(cuid())
  name         String
  code         String?
  category     String?
  unit         String    @default("item")
  unitCost     Float     @default(0)
  stockLevel   Float     @default(0)
  reorderPoint Float     @default(0)
  supplier     String?
  location     String?
  notes        String?
  archivedAt   DateTime?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  @@index([category])
  @@index([code])
  @@index([archivedAt])
}

model PurchaseOrder {
  id               String    @id @default(cuid())
  number           String    @unique
  projectId        String?
  supplier         String
  contactEmail     String?
  contactPhone     String?
  status           String    @default("draft") // draft, sent, received, closed, cancelled
  lineItems        Json      @default("[]")
  subtotal         Float     @default(0)
  vatRate          Float     @default(20)
  vatAmount        Float     @default(0)
  total            Float     @default(0)
  expectedDelivery DateTime?
  receivedAt       DateTime?
  sentAt           DateTime?
  closedAt         DateTime?
  notes            String?
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt
  project          Project?  @relation(fields: [projectId], references: [id], onDelete: SetNull)

  @@index([projectId, status])
  @@index([status])
  @@index([expectedDelivery])
}

model SubInvoice {
  id              String        @id @default(cuid())
  number          String
  subcontractorId String
  projectId       String?
  invoiceDate     DateTime
  description     String?
  netAmount       Float         @default(0)
  vatAmount       Float         @default(0)
  cisAmount       Float         @default(0)
  grossAmount     Float         @default(0)
  payableAmount   Float         @default(0)
  status          String        @default("received") // received, approved, paid, disputed
  paidAt          DateTime?
  notes           String?
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt
  subcontractor   Subcontractor @relation(fields: [subcontractorId], references: [id], onDelete: Cascade)
  project         Project?      @relation(fields: [projectId], references: [id], onDelete: SetNull)

  @@unique([subcontractorId, number])
  @@index([subcontractorId, status])
  @@index([status, invoiceDate])
}

model Drawing {
  id         String            @id @default(cuid())
  projectId  String
  number     String
  title      String
  discipline String? // architectural, structural, electrical, mechanical, plumbing, civil
  status     String            @default("draft") // draft, approved, superseded, archived
  notes      String?
  archivedAt DateTime?
  createdAt  DateTime          @default(now())
  updatedAt  DateTime          @updatedAt
  project    Project           @relation(fields: [projectId], references: [id], onDelete: Cascade)
  revisions  DrawingRevision[]

  @@unique([projectId, number])
  @@index([projectId, status])
  @@index([discipline])
}

model DrawingRevision {
  id         String   @id @default(cuid())
  drawingId  String
  revision   String // e.g. "A", "B", "P01", "T01"
  fileUrl    String?
  fileName   String?
  fileSize   Int?
  mimeType   String?
  notes      String?
  uploadedAt DateTime @default(now())
  drawing    Drawing  @relation(fields: [drawingId], references: [id], onDelete: Cascade)

  @@unique([drawingId, revision])
  @@index([drawingId, uploadedAt])
}

model Milestone {
  id           String    @id @default(cuid())
  projectId    String
  title        String
  plannedStart DateTime
  plannedEnd   DateTime
  actualEnd    DateTime?
  status       String    @default("planned") // planned, in_progress, complete, slipped
  notes        String?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
  project      Project   @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@index([projectId, plannedStart])
  @@index([plannedEnd])
  @@index([status])
}

model Permit {
  id         String    @id @default(cuid())
  projectId  String
  title      String
  type       String    @default("general") // hot_work, confined_space, excavation, working_at_height, electrical, general
  status     String    @default("draft") // draft, active, expired, cancelled
  riskLevel  String    @default("medium") // low, medium, high, critical
  location   String?
  issuedBy   String?
  issuedTo   String?
  validFrom  DateTime?
  validTo    DateTime?
  conditions String?
  notes      String?
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt
  project    Project   @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@index([projectId, status])
  @@index([status, validTo])
  @@index([type])
}

model Rams {
  id        String    @id @default(cuid())
  projectId String
  title     String
  type      String    @default("rams") // rams, risk_assessment, method_statement
  hazards   String?
  controls  String?
  ppe       String?
  reviewBy  DateTime?
  signedBy  String?
  signedAt  DateTime?
  status    String    @default("draft") // draft, active, expired, archived
  notes     String?
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  project   Project   @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@index([projectId, status])
  @@index([reviewBy])
  @@index([type])
}

model Tender {
  id          String    @id @default(cuid())
  projectId   String?
  title       String
  clientName  String?
  status      String    @default("draft") // draft, submitted, won, lost, withdrawn
  totalValue  Float     @default(0)
  deadline    DateTime?
  submittedAt DateTime?
  decidedAt   DateTime?
  notes       String?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  project     Project?  @relation(fields: [projectId], references: [id], onDelete: SetNull)

  @@index([projectId, status])
  @@index([status, deadline])
}

model Inspection {
  id             String    @id @default(cuid())
  projectId      String
  title          String
  type           String    @default("general") // general, safety, quality, scaffold, electrical
  status         String    @default("draft") // draft, in_progress, passed, failed
  checklistItems Json      @default("[]") // [{ id, label, result: 'pass'|'fail'|'na', note? }]
  overallResult  String? // pass, fail
  conductedBy    String?
  scheduledAt    DateTime?
  completedAt    DateTime?
  notes          String?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt
  project        Project   @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@index([projectId, status])
  @@index([scheduledAt])
  @@index([type])
}

model Meeting {
  id          String   @id @default(cuid())
  projectId   String?
  title       String
  location    String?
  scheduledAt DateTime
  durationMin Int      @default(60)
  attendees   String? // newline-separated names
  minutes     String?
  actionItems Json     @default("[]") // [{ id, title, assignee?, dueDate? }]
  status      String   @default("scheduled") // scheduled, completed, cancelled
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  project     Project? @relation(fields: [projectId], references: [id], onDelete: SetNull)

  @@index([projectId, scheduledAt])
  @@index([status, scheduledAt])
}

model Risk {
  id         String    @id @default(cuid())
  projectId  String
  title      String
  category   String    @default("operational") // operational, financial, schedule, safety, quality, environmental
  likelihood Int       @default(3) // 1-5
  impact     Int       @default(3) // 1-5
  score      Int       @default(9) // likelihood × impact, server-computed
  mitigation String?
  owner      String?
  status     String    @default("open") // open, mitigated, accepted, closed
  reviewBy   DateTime?
  notes      String?
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt
  project    Project   @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@index([projectId, status])
  @@index([score])
  @@index([reviewBy])
}

model ToolboxTalk {
  id             String    @id @default(cuid())
  projectId      String?
  date           DateTime
  topic          String
  location       String?
  deliveredBy    String?
  attendees      String? // newline-separated names
  attendeeCount  Int       @default(0)
  hazardsCovered String?
  notes          String?
  signedOff      Boolean   @default(false)
  signedAt       DateTime?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt
  project        Project?  @relation(fields: [projectId], references: [id], onDelete: SetNull)

  @@index([projectId, date])
  @@index([date])
}

model MaintenanceSchedule {
  id           String    @id @default(cuid())
  equipmentId  String
  title        String
  type         String    @default("service") // service, inspection, calibration, repair
  status       String    @default("scheduled") // scheduled, due, completed, overdue, cancelled
  dueDate      DateTime
  intervalDays Int? // when set, completion auto-schedules the next one
  completedAt  DateTime?
  performedBy  String?
  cost         Float     @default(0)
  notes        String?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
  equipment    Equipment @relation(fields: [equipmentId], references: [id], onDelete: Cascade)

  @@index([equipmentId, status])
  @@index([status, dueDate])
  @@index([dueDate])
}

model Supplier {
  id            String    @id @default(cuid())
  name          String
  category      String    @default("materials") // materials, plant, services, other
  contactName   String?
  contactEmail  String?
  contactPhone  String?
  address       String?
  postcode      String?
  paymentTerms  String? // e.g. "Net 30"
  accountNumber String?
  notes         String?
  archivedAt    DateTime?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  @@index([name])
  @@index([category])
  @@index([archivedAt])
}

model SafetyIncident {
  id               String    @id @default(cuid())
  projectId        String?
  title            String
  description      String?
  type             String    @default("near_miss") // near_miss, first_aid, accident, dangerous_occurrence, environmental, security
  severity         String    @default("low") // near_miss, low, medium, high, critical
  status           String    @default("open") // open, investigating, closed
  location         String?
  reportedBy       String?
  injuredParty     String?
  photoUrl         String?
  riddorReportable Boolean   @default(false) // Reportable to HSE under RIDDOR
  occurredAt       DateTime  @default(now())
  closedAt         DateTime?
  notes            String?
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt
  project          Project?  @relation(fields: [projectId], references: [id], onDelete: SetNull)

  @@index([projectId, status])
  @@index([status, occurredAt])
  @@index([severity])
}

model PushSubscription {
  id        String   @id @default(cuid())
  userId    String?
  endpoint  String   @unique
  p256dh    String
  auth      String
  userAgent String?
  createdAt DateTime @default(now())
  lastUsed  DateTime @default(now())
  user      User?    @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([userId])
}

// ─── Multi-tenancy ─────────────────────────────────────────────────────────
// Phase 1 of the v1.0 SaaS plan. New tables are fully additive — existing
// routes ignore them until the codemod adds organizationId filters in a
// follow-up migration. See docs/v1-completion-plan.md.

model Organization {
  id                   String               @id @default(cuid())
  slug                 String               @unique
  name                 String
  plan                 String               @default("trial") // trial / starter / pro / enterprise
  subscriptionStatus   String               @default("active") // active / past_due / cancelled
  trialEndsAt          DateTime?
  stripeCustomerId     String?              @unique
  stripeSubscriptionId String?              @unique
  brandingLogoUrl      String?
  brandingAccent       String?
  createdAt            DateTime             @default(now())
  updatedAt            DateTime             @updatedAt
  members              UserOrganization[]
  invites              OrganizationInvite[]
  auditEvents          AuditEvent[]
}

model UserOrganization {
  id             String       @id @default(cuid())
  userId         String
  organizationId String
  role           String       @default("member") // owner / admin / member / viewer
  joinedAt       DateTime     @default(now())
  user           User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@unique([userId, organizationId])
  @@index([userId])
  @@index([organizationId])
}

model OrganizationInvite {
  id             String       @id @default(cuid())
  organizationId String
  email          String
  role           String       @default("member")
  token          String       @unique
  expiresAt      DateTime
  acceptedAt     DateTime?
  invitedById    String?
  createdAt      DateTime     @default(now())
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@index([organizationId])
  @@index([email])
}

model AuditEvent {
  id             String       @id @default(cuid())
  organizationId String
  userId         String?
  action         String // "project.delete", "invoice.update", etc.
  resourceType   String
  resourceId     String
  metadata       Json?
  ipAddress      String?
  userAgent      String?
  createdAt      DateTime     @default(now())
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@index([organizationId, createdAt])
  @@index([userId, createdAt])
  @@index([resourceType, resourceId])
}

model NotificationPreference {
  id                 String   @id @default(cuid())
  userId             String   @unique
  tasksPush          Boolean  @default(true)
  tasksEmail         Boolean  @default(false)
  safetyPush         Boolean  @default(true)
  safetyEmail        Boolean  @default(true)
  invoicesPush       Boolean  @default(true)
  invoicesEmail      Boolean  @default(true)
  announcementsPush  Boolean  @default(true)
  announcementsEmail Boolean  @default(false)
  weeklyDigest       Boolean  @default(true)
  updatedAt          DateTime @updatedAt
  user               User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}
