{
  "name": "cortexx",
  "version": "1.4.0",
  "description": "The construction OS that thinks with you. UK SMB construction management with autonomous AI CEO.",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build && npm run precompile",
    "start": "next start",
    "lint": "eslint . --max-warnings 100",
    "db:generate": "prisma generate",
    "db:migrate": "prisma migrate deploy",
    "db:push": "prisma db push",
    "db:seed": "ts-node --compiler-options '{\"module\":\"CommonJS\"}' prisma/seed.ts",
    "db:studio": "prisma studio",
    "test": "node --test test/*.test.js",
    "test:integration": "tsx --test test/integration/*.test.js",
    "precompile": "babel lib --out-dir dist --presets @babel/preset-react --copy-files --extensions \".js,.jsx\"",
    "vault:decrypt": "./scripts/decrypt-env.sh",
    "vault:load": "./scripts/load-env.sh",
    "postinstall": "npm run precompile --silent || true",
    "ios:add": "npx cap add ios",
    "ios:sync": "npx cap copy && npx cap sync ios",
    "ios:open": "npx cap open ios",
    "android:add": "npx cap add android",
    "android:open": "npx cap open android"
  },
  "dependencies": {
    "@auth/prisma-adapter": "^2.11.2",
    "@aws-sdk/client-s3": "^3.1085.0",
    "@aws-sdk/s3-request-presigner": "^3.1085.0",
    "@capacitor/android": "^8.4.1",
    "@capacitor/core": "^8.4.1",
    "@capacitor/ios": "^8.4.1",
    "@prisma/client": "^7.8.0",
    "@prisma/adapter-pg": "^7.8.0",
    "@sentry/nextjs": "^10.65.0",
    "@types/qrcode": "^1.5.6",
    "@types/speakeasy": "^2.0.10",
    "@types/web-push": "^3.6.4",
    "bcryptjs": "^3.0.3",
    "ioredis": "^5.10.1",
    "next": "^16.2.9",
    "next-auth": "^5.0.0-beta.31",
    "pdfkit": "^0.19.1",
    "qrcode": "^1.5.4",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "speakeasy": "^2.0.0",
    "stripe": "^22.3.1",
    "web-push": "^3.6.7",
    "web-vitals": "^5.2.0"
  },
  "devDependencies": {
    "@babel/cli": "^7.24.0",
    "@babel/preset-react": "^7.24.0",
    "@babel/standalone": "^7.29.7",
    "@capacitor/cli": "^8.4.1",
    "@next/bundle-analyzer": "^16.2.10",
    "@tailwindcss/forms": "^0.5.7",
    "@tailwindcss/postcss": "^4.3.2",
    "@types/bcryptjs": "^3.0.0",
    "@types/node": "^25.9.5",
    "@types/pdfkit": "^0.17.6",
    "@types/react": "^19.2.16",
    "@types/react-dom": "^19.2.3",
    "autoprefixer": "^10.5.2",
    "eslint": "^9.0.0",
    "eslint-config-next": "^16.2.10",
    "eslint-plugin-react-hooks": "^7.1.1",
    "postcss": "^8.5.17",
    "prisma": "^7.8.0",
    "serve": "^14.2.0",
    "tailwindcss": "^4.3.2",
    "ts-node": "^10.9.2",
    "tsx": "^4.23.0",
    "typescript": "^6.0.3"
  },
  "overrides": {
    "postcss": "^8.5.17",
    "@hono/node-server": "^2.0.8"
  }
}
